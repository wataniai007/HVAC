  }else if(obj.type==='controller'){
    ctx.fillStyle='#EFF6FF';ctx.strokeStyle=sel?'#2563EB':'#1D4ED8';ctx.lineWidth=sel?2.5:1.5;
    rr2(0,0,obj.w,obj.h,4);
    ctx.fillStyle='#1E3A5F';rr2(0,0,obj.w,20,4,true);
    ctx.fillStyle='#fff';ctx.font='bold 8px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(obj.model||'DDC',obj.w/2,10);
    ctx.fillStyle='#374151';ctx.font='7px sans-serif';
    const ch=obj.channels||[];
    ctx.fillText(`AI:${ch.filter(c=>c.cls==='AI').length} AO:${ch.filter(c=>c.cls==='AO').length} DI:${ch.filter(c=>c.cls==='DI').length} DO:${ch.filter(c=>c.cls==='DO').length}`,obj.w/2,34);
