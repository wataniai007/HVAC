  const poleId=S.project?S.project.poleId:null;
  const tree=document.getElementById('lib-tree');if(!tree) return;
  let html='';
  if(S.pinned.length>0&&!filter){
    html+=`<div style="background:#FFFBEB;border-bottom:1px solid #FDE68A;"><div style="padding:6px 10px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#92400E;">⭐ Pinned</div>`;
    S.pinned.forEach(ptId=>{
      const pt=pts.find(x=>x.id===ptId);if(!pt) return;
      const dev=getDefaultDev(pt,poleId);
      html+=`<div class="lib-item" draggable="true" ondragstart="startDrag(event,'${pt.id}')" title="${pt.name}${dev?'\n'+dev.mfr+' '+dev.model:''}">
        <span class="lib-sym">${pt.sym||'⬡'}</span><span style="flex:1;">${pt.name}</span>
        ${dev?`<span style="font-size:9px;color:#9CA3AF;">${dev.model}</span>`:''}
        <button onclick="event.stopPropagation();S.pinned=S.pinned.filter(x=>x!=='${pt.id}');buildLibTree('');" style="background:none;border:none;cursor:pointer;font-size:10px;color:#9CA3AF;padding:0 2px;">✕</button>
      </div>`;
    });
    html+='</div>';
  }
  ls.forEach(lib=>{
    const hasPts=lib.cats.some(cat=>pts.filter(pt=>pt.catId===cat.id&&(!filter||pt.name.toLowerCase().includes(filter.toLowerCase()))).length>0);
    if(!hasPts&&filter) return;
    html+=`<div class="lib-library"><div class="lib-lib-hdr" onclick="toggleLib('${lib.id}')"><span>${lib.exp?'▾':'▸'}</span><span>${lib.name}</span></div>`;
    if(lib.exp||filter){
      lib.cats.forEach(cat=>{
        const catPts=pts.filter(
pt=>pt.catId===cat.id&&(!filter||pt.name.toLowerCase().includes(filter.toLowerCase())));
        if(!catPts.length&&filter) return;
        html+=`<div><div class="lib-cat-hdr" onclick="toggleCat('${lib.id}','${cat.id}')"><span>${cat.exp||filter?'▾':'▸'}</span><span>${cat.name}</span></div>`;
        if(cat.exp||filter){
          catPts.forEach(pt=>{
            const dev=getDefaultDev(pt,poleId);
            html+=`<div class="lib-item" draggable="true" ondragstart="startDrag(event,'${pt.id}')" title="${pt.name}${dev?'\n'+dev.mfr+' '+dev.model:''}">
              <span class="lib-sym">${pt.sym||'⬡'}</span><span style="flex:1;">${pt.name}</span>
              ${dev?`<span style="font-size:9px;color:#9CA3AF;">${dev.model}</span>`:''}
              <button onclick="event.stopPropagation();if(!S.pinned.includes('${pt.id}'))S.pinned.push('${pt.id}');buildLibTree('');" style="background:none;border:none;cursor:pointer;font-size:10px;color:#9CA3AF;padding:0 2px;" title="Pin">⭐</button>
            </div>`;
          });
        }
        html+='</div>';
      });
    }
    html+='</div>';
  });
  tree.innerHTML=html||'<div style="padding:16px;color:#9CA3AF;font-size:11px;text-align:center;">No devices found</div>';
}
function getDefaultDev(pt,poleId){
