    }else{ctx.fillRect(0,0,obj.w,obj.h);ctx.strokeRect(0,0,obj.w,obj.h);}
    ctx.fillStyle=obj.color;ctx.font='7px sans-serif';ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText(obj.label||'',obj.w/2,obj.h/2);
  }else if(obj.type==='device'){
    const r=Math.min(obj.w,obj.h)/2-1;
