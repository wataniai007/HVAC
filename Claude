/* ============================================================
   FINAL BUTTON WIRING CLEANUP
   Catches any buttons not wired by earlier parts.
   ============================================================ */

function finalButtonCleanup() {
  // Export PDF button
  const btnExportPDF = document.getElementById('btn-export-pdf');
  if (btnExportPDF) {
    btnExportPDF.removeEventListener('click', exportDrawingPDF);
    btnExportPDF.addEventListener('click', exportDrawingPDF);
  }

  // Project export/import
  const btnExportJ = document.getElementById('btn-export-json');
  if (btnExportJ) btnExportJ.addEventListener('click', exportProjectJSON);
  const btnImportJ = document.getElementById('btn-import-json');
  if (btnImportJ) btnImportJ.addEventListener('click', importProjectJSON);

  // IO summary modal trigger
  const btnIoSumm = document.getElementById('btn-export-io');
  if (btnIoSumm) btnIoSumm.addEventListener('click', () => {
    if (typeof openIOSummaryModal === 'function') openIOSummaryModal('project', '');
    else if (typeof renderIOView === 'function') renderIOView();
  });

  // Quick help
  const helpBtns = document.querySelectorAll('[onclick*="help"],[data-action="help"]');
  helpBtns.forEach(b => b.addEventListener('click', showQuickHelp));

  // Close any orphaned modals on overlay click
  document.querySelectorAll('.modal-overlay').forEach(m => {
    if (!m.dataset.closeBound) {
      m.dataset.closeBound = '1';
      m.addEventListener('click', e => {
        if (e.target === m) m.classList.add('hidden');
      });
    }
  });

  // Confirm dialog fallback
  const confCan = document.getElementById('conf-cancel') || document.getElementById('confirm-cancel');
  const confOk  = document.getElementById('conf-ok')     || document.getElementById('confirm-ok');
  if (confCan && !confCan.dataset.bound) {
    confCan.dataset.bound = '1';
    confCan.addEventListener('click', () => {
      const ov = document.getElementById('confirm-overlay') || document.getElementById('cw');
      if (ov) ov.classList.add('hidden');
      if (typeof confResolve !== 'undefined' && confResolve) { confResolve(false); }
    });
  }
  if (confOk && !confOk.dataset.bound) {
    confOk.dataset.bound = '1';
    confOk.addEventListener('click', () => {
      const ov = document.getElementById('confirm-overlay') || document.getElementById('cw');
      if (ov) ov.classList.add('hidden');
      if (typeof confResolve !== 'undefined' && confResolve) { confResolve(true); }
    });
  }

  // Project settings tabs fallback
  document.querySelectorAll('#proj-settings-tabs .tab-btn, #part-tabs .tab-btn').forEach(btn => {
    if (!btn.dataset.tabBound) {
      btn.dataset.tabBound = '1';
      btn.addEventListener('click', () => {
        const container = btn.closest('.modal-box') || btn.closest('.modal');
        if (!container) return;
        const tabId = btn.dataset.tab;
        container.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        container.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = document.getElementById(tabId);
        if (panel) panel.classList.add('active');
      });
    }
  });
}

