    + 'h2{font-size:14px;color:#374151;margin:18px 0 6px;border-bottom:1px solid #e5e7eb;padding-bottom:4px}'
    + 'h3{font-size:12px;color:#374151;margin:10px 0 4px}'
    + 'table{width:100%;border-collapse:collapse;margin-bottom:12px}'
    + 'th{background:#1e3a5f;color:#fff;padding:6px 10px;text-align:left;font-size:10px}'
    + 'td{padding:5px 10px;border-bottom:1px solid #e5e7eb}'
    + '.cover{text-align:center;padding:60px 40px;border:2px solid #0f2744;border-radius:8px;margin-bottom:30px}'
    + '.meta-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px 20px;font-size:11px;margin:12px 0}'
    + '.meta-lbl{color:#6b7280;font-size:10px}'
    + '.meta-val{font-weight:600}'
    + '@media print{@page{size:letter}body{margin:16px}}'
    + '</style></head><body>');

  // Cover page
  win.document.write('<div class="cover">');
  win.document.write('<div style="font-size:11px;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Submittal Package</div>');
  win.document.write('<h1>' + proj?.name + '</h1>');
  win.document.write('<div style="font-size:14px;color:#374151;margin-bottom:20px">' + purpose + '</div>');
