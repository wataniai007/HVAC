/* ── P-to-P Canvas State ── */
const PTOP = {
  zoom:     1,
  panX:     60,
  panY:     40,
  tool:     'select',
  objects:  [],   // device cards with terminals
  wires:    [],   // point-to-point wire connections
  selected: null,
  drawing:  null, // wire being drawn
  dragging: null,
  dragOffX: 0,
  dragOffY: 0,
  isDragging: false,
  isPanning:  false,
  panStart:   null
};

let ptopCanvas = null, ptopCtx = null;

function initPtoPCanvas() {
  ptopCanvas = document.getElementById('ptop-canvas');
  if (!ptopCanvas) return;
  ptopCtx = ptopCanvas.getContext('2d');

  const area = document.getElementById('ptop-canvas-area');
  if (area) {
    ptopCanvas.width  = area.clientWidth;
    ptopCanvas.height = area.clientHeight;
  }

  buildPtoPObjects();
  renderPtoPCanvas();
  setupPtoPEvents();
}

function buildPtoPObjects() {
  PTOP.objects = [];
  PTOP.wires   = [];

  const cs = S.canvas || { objects: [] };
  const devices = (cs.objects||[]).filter(o => o.type === 'device' || o.type === 'controller');

  // Lay out device cards in a grid
  const CARD_W = 160;
  const CARD_PADDING = 20;
  let col = 0, row = 0;
  const COLS = 3;

  devices.forEach(dev => {
    const pts = dev.points || [];
    const termCount = pts.reduce((n, pt) => {
      const wopt = (pt.opts||[]).find(o => o.id === (pt.selectedWire||pt.defW)) || pt.opts?.[0];
      return n + (wopt ? (wopt.terms||[]).length : 0);
    }, 0);

    const CARD_H = Math.max(80, 30 + termCount * 18);
    const x = 60 + col * (CARD_W + CARD_PADDING);
    const y = 60 + row * (CARD_H + CARD_PADDING + 30);

    const card = {
      id:       dev.id,
      objRef:   dev,
      x, y,
      w:        CARD_W,
      h:        CARD_H,
      label:    dev.tag || dev.model || '',
      model:    dev.model || '',
      mfr:      dev.mfr   || dev.manufacturer || '',
      terminals: []
    };

    // Build terminals for this card
    let termY = 30;
    pts.forEach((pt, pi) => {
      if (!pt.wireToController && !pt.controllerId) return;
      const wopt = (pt.opts||[]).find(o => o.id === (pt.selectedWire||pt.defW)) || pt.opts?.[0];
      const terms = wopt ? (wopt.terms||[]) : ['T1','T2'];

      terms.forEach((termLabel, ti) => {
        card.terminals.push({
          id:       dev.id + '_' + pi + '_' + ti,
          devId:    dev.id,
          pointIdx: pi,
          termIdx:  ti,
          label:    termLabel,
          relX:     CARD_W,   // right side of card
          relY:     termY,
          side:     'right',
          signal:   wopt ? wopt.sig : '',
          ioClass:  wopt ? wopt.ioClass : 'AI',
          wireColor:getWireColor(wopt, S.project),
          connectedTo: null   // will be filled by auto-route
        });
        termY += 18;
      });

      // Common/GND terminal on left
      if (wopt && wopt.wires >= 2) {
        card.terminals.push({
          id:       dev.id + '_' + pi + '_COM',
          devId:    dev.id,
          pointIdx: pi,
          termIdx:  100 + pi,
          label:    'COM',
          relX:     0,
          relY:     termY - 9,
          side:     'left',
          signal:   'GND',
          ioClass:  'GND',
          wireColor:'#111827',
          connectedTo: null
        });
      }
    });

    PTOP.objects.push(card);

    col++;
    if (col >= COLS) { col = 0; row++; }
  });

  // Add a controller "panel" card if controllers exist
  const controllers = (cs.objects||[]).filter(o => o.type === 'controller');
  controllers.forEach((ctrl, ci) => {
    const chs = ctrl.channels || [];
    const CTRL_H = Math.max(100, 30 + chs.length * 16);
    const x = 60 + (COLS) * (CARD_W + CARD_PADDING) + 40;
    const y = 60 + ci * (CTRL_H + 40);

    const card = {
      id:        ctrl.id + '_panel',
      objRef:    ctrl,
      x, y,
      w:         CARD_W + 20,
      h:         CTRL_H,
      label:     ctrl.tag || ctrl.model || '',
      model:     ctrl.model || '',
      mfr:       ctrl.mfr || ctrl.manufacturer || '',
      isController: true,
      terminals: []
    };

    let termY = 26;
    chs.forEach((ch, chi) => {
      card.terminals.push({
        id:       ctrl.id + '_ch_' + ch.id,
        devId:    ctrl.id,
        chId:     ch.id,
        label:    ch.id,
        relX:     0,   // left side — things wire IN from the left
        relY:     termY,
        side:     'left',
        signal:   (ch.sigs||[])[0] || '',
        ioClass:  ch.cls || 'AI',
        wireColor:getWireColor({ ioClass: ch.cls }, S.project),
        assigned: ch.assigned || null,
        connectedTo: null
      });
      termY += 16;
    });

    PTOP.objects.push(card);
  });

  // Add PSU and generic power bus cards
  const hasPSU = (cs.objects||[]).some(o => o.type === 'device' && (o.model||'').toLowerCase().includes('ps'));
  const psuCard = {
    id: '_psu_generic',
    x: 60,
    y: 60 + Math.ceil(Math.max(1, devices.length) / COLS) * 130 + 40,
    w: CARD_W,
    h: 80,
    label: 'Power Supply',
    model: hasPSU ? 'Assigned PSU' : '24VAC Generic',
    mfr: '',
    isPSU: true,
    terminals: [
      { id:'_psu_pos', devId:'_psu', label:'+24V', relX:CARD_W, relY:20, side:'right', signal:'24Vac', ioClass:'PWR', wireColor:'#10b981', connectedTo:null },
      { id:'_psu_neg', devId:'_psu', label:'COM',  relX:CARD_W, relY:40, side:'right', signal:'COM',   ioClass:'GND', wireColor:'#111827', connectedTo:null },
      { id:'_psu_gnd', devId:'_psu', label:'GND',  relX:CARD_W, relY:60, side:'right', signal:'GND',   ioClass:'GND', wireColor:'#374151', connectedTo:null }
    ]
  };
  PTOP.objects.push(psuCard);
}

function renderPtoPCanvas() {
  if (!ptopCtx || !ptopCanvas) return;
  ptopCtx.clearRect(0, 0, ptopCanvas.width, ptopCanvas.height);

  ptopCtx.save();
  ptopCtx.translate(PTOP.panX, PTOP.panY);
  ptopCtx.scale(PTOP.zoom, PTOP.zoom);

  drawPtoPGrid();
  drawPtoPWires();
  if (PTOP.drawing) drawPtoPWirePreview();
  PTOP.objects.forEach(card => drawPtoPCard(card));

  ptopCtx.restore();
}

function drawPtoPGrid() {
  const step = 20;
  const w = ptopCanvas.width  / PTOP.zoom;
  const h = ptopCanvas.height / PTOP.zoom;
  const ox = -PTOP.panX / PTOP.zoom;
  const oy = -PTOP.panY / PTOP.zoom;
  ptopCtx.strokeStyle = '#e8ecf0';
  ptopCtx.lineWidth = 0.4;
  for (let x = Math.floor(ox/step)*step; x < ox+w; x+=step) { ptopCtx.beginPath(); ptopCtx.moveTo(x,oy); ptopCtx.lineTo(x,oy+h); ptopCtx.stroke(); }
  for (let y = Math.floor(oy/step)*step; y < oy+h; y+=step) { ptopCtx.beginPath(); ptopCtx.moveTo(ox,y); ptopCtx.lineTo(ox+w,y); ptopCtx.stroke(); }
}

function drawPtoPCard(card) {
  const sel = PTOP.selected === card.id;
  const x = card.x, y = card.y, w = card.w, h = card.h;

  // Card shadow
  ptopCtx.shadowColor = 'rgba(0,0,0,.1)';
  ptopCtx.shadowBlur  = 6;
  ptopCtx.shadowOffsetX = 2;
  ptopCtx.shadowOffsetY = 2;

  // Card body
  ptopCtx.fillStyle   = card.isPSU ? '#f0fdf4' : card.isController ? '#eff6ff' : '#fff';
  ptopCtx.strokeStyle = sel ? '#2563eb' : card.isPSU ? '#6ee7b7' : card.isController ? '#1d4ed8' : '#d1d5db';
  ptopCtx.lineWidth   = sel ? 2 : 1;
  ptopCtx.beginPath();
  ptopCtx.roundRect(x, y, w, h, 6);
  ptopCtx.fill();
  ptopCtx.stroke();
  ptopCtx.shadowBlur = 0; ptopCtx.shadowOffsetX = 0; ptopCtx.shadowOffsetY = 0;

  // Header bar
  ptopCtx.fillStyle = card.isPSU ? '#10b981' : card.isController ? '#1e3a5f' : '#374151';
  ptopCtx.beginPath();
  ptopCtx.roundRect(x, y, w, 22, [6, 6, 0, 0]);
  ptopCtx.fill();

  // Header text
  ptopCtx.fillStyle = '#fff';
  ptopCtx.font = 'bold 9px Segoe UI,Arial';
  ptopCtx.textAlign = 'left';
  ptopCtx.textBaseline = 'middle';
  ptopCtx.fillText(card.label || '', x + 7, y + 11);

  // Model text
  if (card.model) {
    ptopCtx.fillStyle = '#9ca3af';
    ptopCtx.font = '8px Segoe UI,Arial';
    ptopCtx.fillText(card.model, x + 7, y + 28);
  }

  // Draw terminals
  (card.terminals || []).forEach(term => drawTerminal(card, term));
}

function drawTerminal(card, term) {
  const tx = card.x + term.relX;
  const ty = card.y + term.relY;
  const isRight = term.side === 'right';
  const isConn  = !!term.connectedTo;

  // Terminal line stub
  ptopCtx.strokeStyle = term.wireColor || '#6b7280';
  ptopCtx.lineWidth   = 1.2;
  ptopCtx.beginPath();
  ptopCtx.moveTo(tx, ty);
  ptopCtx.lineTo(tx + (isRight ? 12 : -12), ty);
  ptopCtx.stroke();

  // Terminal dot
  ptopCtx.fillStyle = isConn ? (term.wireColor || '#6b7280') : '#fff';
  ptopCtx.strokeStyle = term.wireColor || '#6b7280';
  ptopCtx.lineWidth = 1.5;
  ptopCtx.beginPath();
  ptopCtx.arc(tx + (isRight ? 12 : -12), ty, 4, 0, Math.PI * 2);
  ptopCtx.fill();
  ptopCtx.stroke();

  // Terminal label
  ptopCtx.fillStyle = '#374151';
  ptopCtx.font = '8px Segoe UI,Arial';
  ptopCtx.textAlign = isRight ? 'right' : 'left';
  ptopCtx.textBaseline = 'middle';
  ptopCtx.fillText(term.label || '', tx + (isRight ? -3 : 3), ty);

  // Signal label beside terminal dot
  ptopCtx.fillStyle = '#9ca3af';
  ptopCtx.font = '7px Segoe UI,Arial';
  ptopCtx.textAlign = isRight ? 'left' : 'right';
  const sigX = tx + (isRight ? 18 : -18);
  ptopCtx.fillText(term.signal || '', sigX, ty);
}

function drawPtoPWires() {
  PTOP.wires.forEach(wire => {
    const from = findTerminalById(wire.fromTermId);
    const to   = findTerminalById(wire.toTermId);
    if (!from || !to) return;

    const x1 = getTermAbsX(from);
    const y1 = getTermAbsY(from);
    const x2 = getTermAbsX(to);
    const y2 = getTermAbsY(to);

    ptopCtx.save();
    ptopCtx.strokeStyle = wire.color || from.wireColor || '#6b7280';
    ptopCtx.lineWidth   = 1.5;

    ptopCtx.beginPath();
    ptopCtx.moveTo(x1, y1);

    if (wire.waypoints && wire.waypoints.length) {
      wire.waypoints.forEach(wp => ptopCtx.lineTo(wp.x, wp.y));
    } else {
      // Orthogonal routing — go right from source then across
      const midX = (x1 + x2) / 2;
      ptopCtx.lineTo(midX, y1);
      ptopCtx.lineTo(midX, y2);
    }

    ptopCtx.lineTo(x2, y2);
    ptopCtx.stroke();

    // Wire number badge
    if (wire.wireNum) {
      const midX = (x1 + x2) / 2;
      const midY = (y1 + y2) / 2;
      ptopCtx.fillStyle = '#1e3a5f';
      ptopCtx.beginPath();
      ptopCtx.roundRect(midX - 8, midY - 7, 16, 14, 3);
      ptopCtx.fill();
      ptopCtx.fillStyle = '#fff';
      ptopCtx.font = 'bold 7px Segoe UI,Arial';
      ptopCtx.textAlign = 'center';
      ptopCtx.textBaseline = 'middle';
      ptopCtx.fillText(String(wire.wireNum), midX, midY);
    }

    // Arrow at destination
    const angle = Math.atan2(y2 - y1, x2 - x1);
    ptopCtx.fillStyle = wire.color || from.wireColor || '#6b7280';
    ptopCtx.beginPath();
    ptopCtx.moveTo(x2, y2);
    ptopCtx.lineTo(x2 - 8 * Math.cos(angle - 0.3), y2 - 8 * Math.sin(angle - 0.3));
    ptopCtx.lineTo(x2 - 8 * Math.cos(angle + 0.3), y2 - 8 * Math.sin(angle + 0.3));
    ptopCtx.closePath();
    ptopCtx.fill();

    ptopCtx.restore();
  });
}

function drawPtoPWirePreview() {
  const d = PTOP.drawing;
  if (!d) return;
  ptopCtx.save();
  ptopCtx.strokeStyle = '#2563eb';
  ptopCtx.lineWidth   = 1.5;
  ptopCtx.setLineDash([5, 4]);
  const midX = (d.sx + d.ex) / 2;
  ptopCtx.beginPath();
  ptopCtx.moveTo(d.sx, d.sy);
  ptopCtx.lineTo(midX, d.sy);
  ptopCtx.lineTo(midX, d.ey);
  ptopCtx.lineTo(d.ex, d.ey);
  ptopCtx.stroke();
  ptopCtx.setLineDash([]);
  ptopCtx.restore();
}

/* ── Terminal lookup helpers ── */
function findTerminalById(id) {
  for (const card of PTOP.objects) {
    const term = (card.terminals||[]).find(t => t.id === id);
    if (term) return { card, term };
  }
  return null;
}

function getTermAbsX(found) {
  return found.card.x + found.term.relX + (found.term.side === 'right' ? 12 : -12);
}

function getTermAbsY(found) {
  return found.card.y + found.term.relY;
}

function hitTestPtoPTerminal(wx, wy) {
  for (const card of PTOP.objects) {
    for (const term of (card.terminals||[])) {
      const tx = card.x + term.relX + (term.side === 'right' ? 12 : -12);
      const ty = card.y + term.relY;
      if (Math.abs(wx - tx) < 8 && Math.abs(wy - ty) < 8) return { card, term };
    }
  }
  return null;
}

function hitTestPtoPCard(wx, wy) {
  for (let i = PTOP.objects.length - 1; i >= 0; i--) {
    const c = PTOP.objects[i];
    if (wx >= c.x && wx <= c.x + c.w && wy >= c.y && wy <= c.y + c.h) return c;
  }
  return null;
}

function ptopToWorld(cx, cy) {
  return {
    wx: (cx - PTOP.panX) / PTOP.zoom,
    wy: (cy - PTOP.panY) / PTOP.zoom
  };
}

/* ── P-to-P Canvas Events ── */
function setupPtoPEvents() {
  if (!ptopCanvas) return;

  ptopCanvas.addEventListener('mousedown', e => {
    const { wx, wy } = ptopToWorld(e.offsetX, e.offsetY);

    if (e.button === 1 || (e.button === 0 && e.altKey)) {
      PTOP.isPanning = true;
      PTOP.panStart  = { x: e.clientX - PTOP.panX, y: e.clientY - PTOP.panY };
      ptopCanvas.style.cursor = 'grabbing';
      return;
    }

    if (PTOP.tool === 'select') {
      const termHit = hitTestPtoPTerminal(wx, wy);
      if (termHit) {
        // Start wiring from terminal
        PTOP.drawing = {
          sx: getTermAbsX(termHit),
          sy: getTermAbsY(termHit),
          ex: wx, ey: wy,
          fromTermId: termHit.term.id,
          fromColor:  termHit.term.wireColor
        };
        return;
      }
      const cardHit = hitTestPtoPCard(wx, wy);
      if (cardHit) {
        PTOP.selected  = cardHit.id;
        PTOP.isDragging= true;
        PTOP.dragging  = cardHit;
        PTOP.dragOffX  = wx - cardHit.x;
        PTOP.dragOffY  = wy - cardHit.y;
      } else {
        PTOP.selected = null;
      }
      renderPtoPCanvas();

    } else if (PTOP.tool === 'wire') {
      const termHit = hitTestPtoPTerminal(wx, wy);
      if (termHit) {
        PTOP.drawing = {
          sx: getTermAbsX(termHit),
          sy: getTermAbsY(termHit),
          ex: wx, ey: wy,
          fromTermId: termHit.term.id,
          fromColor:  termHit.term.wireColor
        };
      }
    }
  });

  ptopCanvas.addEventListener('mousemove', e => {
    const { wx, wy } = ptopToWorld(e.offsetX, e.offsetY);

    if (PTOP.isPanning) {
      PTOP.panX = e.clientX - PTOP.panStart.x;
      PTOP.panY = e.clientY - PTOP.panStart.y;
      renderPtoPCanvas();
      return;
    }

    if (PTOP.isDragging && PTOP.dragging) {
      PTOP.dragging.x = wx - PTOP.dragOffX;
      PTOP.dragging.y = wy - PTOP.dragOffY;
      renderPtoPCanvas();
      return;
    }

    if (PTOP.drawing) {
      PTOP.drawing.ex = wx;
      PTOP.drawing.ey = wy;
      renderPtoPCanvas();
    }

    const termHit = hitTestPtoPTerminal(wx, wy);
    ptopCanvas.style.cursor = termHit ? 'crosshair' : PTOP.isDragging ? 'grabbing' : 'default';
  });

  ptopCanvas.addEventListener('mouseup', e => {
    const { wx, wy } = ptopToWorld(e.offsetX, e.offsetY);

    if (PTOP.isPanning) { PTOP.isPanning = false; ptopCanvas.style.cursor = 'default'; return; }
    if (PTOP.isDragging) { PTOP.isDragging = false; PTOP.dragging = null; renderPtoPCanvas(); return; }

    if (PTOP.drawing) {
      const termHit = hitTestPtoPTerminal(wx, wy);
      if (termHit && termHit.term.id !== PTOP.drawing.fromTermId) {
        // Create wire
        const maxWire = Math.max(0, ...PTOP.wires.map(w => w.wireNum || 0));
        PTOP.wires.push({
          id:         'w_' + Date.now(),
          fromTermId: PTOP.drawing.fromTermId,
          toTermId:   termHit.term.id,
          color:      PTOP.drawing.fromColor || '#6b7280',
          waypoints:  [],
          wireNum:    maxWire + 1
        });
        // Mark terminals as connected
        const fromFound = findTerminalById(PTOP.drawing.fromTermId);
        if (fromFound) fromFound.term.connectedTo = termHit.term.id;
        termHit.term.connectedTo = PTOP.drawing.fromTermId;

        renderWireSchedule();
        if (typeof addAudit === 'function') addAudit('canvas', 'P-to-P wire added');
      }
      PTOP.drawing = null;
      renderPtoPCanvas();
    }
  });

  ptopCanvas.addEventListener('wheel', e => {
    e.preventDefault();
    ptopZoom(e.deltaY < 0 ? 1.1 : 0.9, e.offsetX, e.offsetY);
  }, { passive: false });

  ptopCanvas.addEventListener('dblclick', e => {
    if (PTOP.tool === 'waypoint') {
      const { wx, wy } = ptopToWorld(e.offsetX, e.offsetY);
      // Add waypoint to nearest wire
      if (PTOP.wires.length) {
        PTOP.wires[PTOP.wires.length - 1].waypoints.push({ x: wx, y: wy });
        renderPtoPCanvas();
      }
    }
  });
}

function ptopZoom(factor, px, py) {
  if (!ptopCanvas) return;
  if (px === undefined) px = ptopCanvas.width / 2;
  if (py === undefined) py = ptopCanvas.height / 2;
  const prev = PTOP.zoom;
  PTOP.zoom  = Math.min(4, Math.max(0.1, prev * factor));
  PTOP.panX  = px - (px - PTOP.panX) * (PTOP.zoom / prev);
  PTOP.panY  = py - (py - PTOP.panY) * (PTOP.zoom / prev);
  const lbl  = document.getElementById('ptop-zoom-lbl');
  if (lbl) lbl.textContent = Math.round(PTOP.zoom * 100) + '%';
  renderPtoPCanvas();
}

function setPTopTool(tool) {
  PTOP.tool = tool;
  ['select','wire','waypoint'].forEach(t => {
    const btn = document.getElementById('ptop-tool-' + t);
    if (btn) btn.classList.toggle('active', t === tool);
  });
  if (ptopCanvas) ptopCanvas.style.cursor = tool === 'select' ? 'default' : 'crosshair';
}

/* ── Auto-Route ── */
function ptopAutoRoute() {
  if (!S.canvas || !S.canvas.objects) return;

  const cs = S.canvas.objects;
  let wireNum = PTOP.wires.length + 1;

  // For each device that has a controller assignment, draw a wire
  // from its terminal to the controller channel terminal
  cs.filter(o => o.type === 'device').forEach(dev => {
    (dev.points || []).forEach((pt, pi) => {
      if (!pt.controllerId || !pt.assignedChannel) return;

      const devCard = PTOP.objects.find(c => c.id === dev.id);
      const ctrlCard = PTOP.objects.find(c => c.id === pt.controllerId + '_panel');
      if (!devCard || !ctrlCard) return;

      const wopt = (pt.opts||[]).find(o => o.id === (pt.selectedWire||pt.defW)) || pt.opts?.[0];
      const terms = wopt ? (wopt.terms||[]) : [];

      terms.forEach((termLabel, ti) => {
        const fromTermId = dev.id + '_' + pi + '_' + ti;
        const toTermId   = pt.controllerId + '_ch_' + pt.assignedChannel;

        // Don't add if wire already exists
        if (PTOP.wires.find(w => w.fromTermId === fromTermId)) return;

        const fromFound = findTerminalById(fromTermId);
        const toFound   = findTerminalById(toTermId);
        if (!fromFound || !toFound) return;

        PTOP.wires.push({
          id:         'aw_' + fromTermId,
          fromTermId,
          toTermId,
          color:      wopt ? getWireColor(wopt, S.project) : '#6b7280',
          waypoints:  [],
          wireNum:    pt.wireNum || wireNum++
        });

        fromFound.term.connectedTo = toTermId;
        toFound.term.connectedTo   = fromTermId;
      });

      // COM wire to PSU
      const comTermId = dev.id + '_' + pi + '_COM';
      const psuTermId = '_psu_neg';
      if (!PTOP.wires.find(w => w.fromTermId === comTermId)) {
        const fromFound = findTerminalById(comTermId);
        const toFound   = findTerminalById(psuTermId);
        if (fromFound && toFound) {
          PTOP.wires.push({
            id:         'com_' + comTermId,
            fromTermId: comTermId,
            toTermId:   psuTermId,
            color:      '#111827',
            waypoints:  [],
            wireNum:    wireNum++
          });
          fromFound.term.connectedTo = psuTermId;
          toFound.term.connectedTo   = comTermId;
        }
      }

      // Power wire for non-loop-powered points
      if (wopt && !wopt.lp && wopt.wires >= 2) {
        const pwrTermId  = dev.id + '_' + pi + '_PWR';
        const psuPosId   = '_psu_pos';
        if (!PTOP.wires.find(w => w.fromTermId === pwrTermId)) {
          const fromFound = findTerminalById(pwrTermId);
          const toFound   = findTerminalById(psuPosId);
          if (fromFound && toFound) {
            PTOP.wires.push({
              id:         'pwr_' + pwrTermId,
              fromTermId: pwrTermId,
              toTermId:   psuPosId,
              color:      '#10b981',
              waypoints:  [],
              wireNum:    wireNum++
            });
            fromFound.term.connectedTo = psuPosId;
            toFound.term.connectedTo   = pwrTermId;
          }
        }
      }
    });
  });

  renderPtoPCanvas();
  renderWireSchedule();
  toast('Auto-route complete — ' + PTOP.wires.length + ' wires routed', 'success');
}

/* ── Wire Schedule Panel ── */
function renderWireSchedule() {
  const el = document.getElementById('wire-schedule-body');
  if (!el) return;

  if (!PTOP.wires.length) {
    el.innerHTML = '<div style="padding:14px;font-size:11px;color:#9ca3af;text-align:center">No wires yet. Use Auto-Route or draw wires manually.</div>';
    return;
  }

  const bc = { AI:'badge-blue', AO:'badge-green', DI:'badge-yellow', DO:'badge-red', GND:'badge-gray', PWR:'badge-green' };

  el.innerHTML = '<table style="width:100%;border-collapse:collapse;font-size:10px"><thead><tr style="background:#1e3a5f;color:#fff">'
    + '<th style="padding:5px 8px;text-align:left">W#</th>'
    + '<th style="padding:5px 8px;text-align:left">From</th>'
    + '<th style="padding:5px 8px;text-align:left">To</th>'
    + '<th style="padding:5px 8px;text-align:left">Signal</th>'
    + '</tr></thead><tbody>'
    + PTOP.wires.map(w => {
        const from = findTerminalById(w.fromTermId);
        const to   = findTerminalById(w.toTermId);
        const fromLabel = from ? (from.card.label + ' / ' + from.term.label) : w.fromTermId;
        const toLabel   = to   ? (to.card.label   + ' / ' + to.term.label)   : w.toTermId;
        const sig = from ? from.term.signal : '';
        return '<tr style="border-bottom:1px solid #f3f4f6">'
          + '<td style="padding:4px 8px"><span style="background:#1e3a5f;color:#fff;padding:1px 5px;border-radius:3px;font-size:9px;font-weight:700">' + w.wireNum + '</span></td>'
          + '<td style="padding:4px 8px;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#374151">' + fromLabel + '</td>'
          + '<td style="padding:4px 8px;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#374151">' + toLabel + '</td>'
          + '<td style="padding:4px 8px"><span class="badge ' + (bc[from?.term?.ioClass] || 'badge-gray') + '" style="font-size:9px">' + sig + '</span></td>'
          + '</tr>';
      }).join('')
    + '</tbody></table>';
}

