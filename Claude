function initEncCanvas() {
  encCanvas = document.getElementById('enc-canvas');
  if (!encCanvas) return;
  encCtx = encCanvas.getContext('2d');
  const area = document.getElementById('enc-canvas-area');
  if (area) { encCanvas.width = area.clientWidth; encCanvas.height = area.clientHeight; }
  setupEncEvents();
}

function encBuildDevices() {
  ENC.layout.devices = [];
  const cs = S.canvas || { objects: [] };
  const panelObjs = (cs.objects||[]).filter(o => o.type === 'device' || o.type === 'controller');

  panelObjs.forEach((obj, i) => {
    const parts = [...(typeof getParts === 'function' ? getParts() : []), ...(typeof getControllers === 'function' ? getControllers() : [])];
    const part  = parts.find(p => p.id === (obj.devId || obj.ctrlId));
    ENC.layout.devices.push({
      id:        obj.id,
      tag:       obj.tag || '',
      model:     obj.model || '',
      widthMm:   part?.widthMm  || 45,
      heightMm:  part?.heightMm || 90,
      dinUnits:  part?.dinUnits || 1,
      color:     obj.color || '#2563eb',
      x:         20 + (i % 5) * 50,
      y:         30 + Math.floor(i / 5) * 100,
      selected:  false
    });
  });
}

function encAutoLayout() {
  const w = parseInt(document.getElementById('enc-w')?.value) || ENC.layout.widthMm;
  const h = parseInt(document.getElementById('enc-h')?.value) || ENC.layout.heightMm;
  const dinCount = parseInt(document.getElementById('enc-din')?.value) || ENC.layout.dinRails;
  ENC.layout.widthMm  = w;
  ENC.layout.heightMm = h;
  ENC.layout.dinRails = dinCount;

  const scale = ENC.zoom;
  const usableW = (w - 20) * scale;
  const railSpacing = (h * scale) / (dinCount + 1);

  let curRail = 1;
  let curX    = 10 * scale;

  const sorted = [...ENC.layout.devices].sort((a, b) => b.dinUnits - a.dinUnits);
  sorted.forEach(dev => {
    const dw = dev.widthMm * scale;
    if (curX + dw > usableW + 10 * scale && curRail < dinCount) {
      curRail++;
      curX = 10 * scale;
    }
    const railY = railSpacing * curRail;
    dev.x = curX;
    dev.y = railY - (dev.heightMm * scale) / 2;
    curX += dw + 4;
  });

  renderEncCanvas();
  encUpdateCapacity();
}

function renderEncCanvas() {
  if (!encCtx || !encCanvas) return;
  encCtx.clearRect(0, 0, encCanvas.width, encCanvas.height);

  encCtx.save();
  encCtx.translate(ENC.panX, ENC.panY);

  const scale  = ENC.zoom;
  const W      = ENC.layout.widthMm  * scale;
  const H      = ENC.layout.heightMm * scale;
  const dinCnt = ENC.layout.dinRails;
  const railSp = H / (dinCnt + 1);

  // Enclosure outline
  encCtx.shadowColor = 'rgba(0,0,0,.15)';
  encCtx.shadowBlur  = 10;
  encCtx.shadowOffsetX = 3;
  encCtx.shadowOffsetY = 3;
  encCtx.fillStyle   = '#fafafa';
  encCtx.strokeStyle = '#374151';
  encCtx.lineWidth   = 2;
  encCtx.fillRect(0, 0, W, H);
  encCtx.strokeRect(0, 0, W, H);
  encCtx.shadowBlur = 0; encCtx.shadowOffsetX = 0; encCtx.shadowOffsetY = 0;

  // Grid dots
  encCtx.fillStyle = '#e5e7eb';
  for (let mx = 5; mx < ENC.layout.widthMm; mx += 5) {
    for (let my = 5; my < ENC.layout.heightMm; my += 5) {
      encCtx.beginPath();
      encCtx.arc(mx * scale, my * scale, 0.8, 0, Math.PI * 2);
      encCtx.fill();
    }
  }

  // DIN rails
  for (let r = 1; r <= dinCnt; r++) {
    const ry = railSp * r;
    encCtx.strokeStyle = '#94a3b8';
    encCtx.lineWidth   = 3;
    encCtx.beginPath();
    encCtx.moveTo(10 * scale, ry);
    encCtx.lineTo(W - 10 * scale, ry);
    encCtx.stroke();

    encCtx.fillStyle = '#64748b';
    encCtx.font      = '8px Segoe UI,Arial';
    encCtx.textAlign = 'left';
    encCtx.textBaseline = 'bottom';
    encCtx.fillText('DIN-' + r, 12 * scale, ry - 2);
  }

  // Devices
  ENC.layout.devices.forEach(dev => {
    const dw  = dev.widthMm  * scale;
    const dh  = dev.heightMm * scale;
    const sel = dev.selected;

    encCtx.shadowColor = 'rgba(0,0,0,.1)';
    encCtx.shadowBlur  = sel ? 8 : 4;

    encCtx.fillStyle   = dev.color + '22';
    encCtx.strokeStyle = sel ? '#2563eb' : dev.color;
    encCtx.lineWidth   = sel ? 2 : 1;
    encCtx.fillRect(dev.x, dev.y, dw, dh);
    encCtx.strokeRect(dev.x, dev.y, dw, dh);
    encCtx.shadowBlur = 0;

    // Device label
    encCtx.fillStyle = dev.color;
    encCtx.font      = 'bold 7px Segoe UI,Arial';
    encCtx.textAlign = 'center';
    encCtx.textBaseline = 'top';
    const lines = (dev.tag + '\n' + dev.model).split('\n');
    lines.forEach((line, i) => {
      encCtx.fillText(line, dev.x + dw / 2, dev.y + 3 + i * 8);
    });

    // Dimension annotation
    encCtx.fillStyle = '#9ca3af';
    encCtx.font      = '6px Segoe UI,Arial';
    encCtx.textAlign = 'center';
    encCtx.textBaseline = 'bottom';
    encCtx.fillText(dev.widthMm + 'mm', dev.x + dw / 2, dev.y + dh - 1);
  });

  encCtx.restore();
}

function encUpdateCapacity() {
  const scale   = ENC.zoom;
  const usedMm  = ENC.layout.devices.reduce((s, d) => s + d.widthMm, 0);
  const availMm = (ENC.layout.widthMm - 20) * ENC.layout.dinRails;
  const pct     = Math.min(100, Math.round(usedMm / availMm * 100));

  const usedEl  = document.getElementById('enc-used-mm');
  const availEl = document.getElementById('enc-avail-mm');
  const bar     = document.getElementById('enc-cap-bar');

  if (usedEl)  usedEl.textContent  = usedMm + ' mm';
  if (availEl) availEl.textContent = availMm + ' mm';
  if (bar) {
    bar.style.width      = pct + '%';
    bar.style.background = pct > 90 ? '#ef4444' : pct > 70 ? '#f59e0b' : '#10b981';
  }
}

function renderEncDeviceList() {
  const el = document.getElementById('enc-device-list');
  if (!el) return;
  el.innerHTML = ENC.layout.devices.map(dev =>
    `<div style="display:flex;align-items:center;gap:6px;padding:5px 0;border-bottom:1px solid #f3f4f6;font-size:11px">
      <div style="width:8px;height:8px;border-radius:50%;background:${dev.color};flex-shrink:0"></div>
      <span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${dev.tag}</span>
      <span style="font-size:10px;color:#9ca3af">${dev.widthMm}mm</span>
    </div>`
  ).join('') || '<div style="font-size:11px;color:#9ca3af">No devices on canvas</div>';
}

function setupEncEvents() {
  if (!encCanvas) return;

  encCanvas.addEventListener('mousedown', e => {
    const wx = (e.offsetX - ENC.panX);
    const wy = (e.offsetY - ENC.panY);

    if (e.button === 1 || (e.button === 0 && e.altKey)) {
      ENC.isPanning = true;
      ENC.panStart  = { x: e.clientX - ENC.panX, y: e.clientY - ENC.panY };
      encCanvas.style.cursor = 'grabbing';
      return;
    }

    const hit = ENC.layout.devices.find(d => {
      const dw = d.widthMm * ENC.zoom;
      const dh = d.heightMm * ENC.zoom;
      return wx >= d.x && wx <= d.x + dw && wy >= d.y && wy <= d.y + dh;
    });

    ENC.layout.devices.forEach(d => d.selected = false);
    if (hit) {
      hit.selected  = true;
      ENC.dragging  = hit;
      ENC.dragOffX  = wx - hit.x;
      ENC.dragOffY  = wy - hit.y;
    }
    renderEncCanvas();
  });

  encCanvas.addEventListener('mousemove', e => {
    if (ENC.isPanning) {
      ENC.panX = e.clientX - ENC.panStart.x;
      ENC.panY = e.clientY - ENC.panStart.y;
      renderEncCanvas();
      return;
    }
    if (ENC.dragging) {
      const wx = e.offsetX - ENC.panX;
      const wy = e.offsetY - ENC.panY;
      ENC.dragging.x = Math.max(0, wx - ENC.dragOffX);
      ENC.dragging.y = Math.max(0, wy - ENC.dragOffY);
      renderEncCanvas();
    }
  });

  encCanvas.addEventListener('mouseup', () => {
    ENC.isPanning = false;
    ENC.dragging  = null;
    encCanvas.style.cursor = 'default';
    encUpdateCapacity();
  });

  encCanvas.addEventListener('wheel', e => {
    e.preventDefault();
    const f = e.deltaY < 0 ? 1.1 : 0.9;
    ENC.zoom = Math.min(6, Math.max(0.5, ENC.zoom * f));
    const lbl = document.getElementById('enc-zoom-lbl');
    if (lbl) lbl.textContent = Math.round(ENC.zoom / 1.5 * 100) + '%';
    encAutoLayout();
  }, { passive: false });
}

function encZoomIn()  { ENC.zoom = Math.min(6, ENC.zoom * 1.2); const lbl=document.getElementById('enc-zoom-lbl');if(lbl)lbl.textContent=Math.round(ENC.zoom/1.5*100)+'%'; encAutoLayout(); }
function encZoomOut() { ENC.zoom = Math.max(0.5, ENC.zoom * 0.8); const lbl=document.getElementById('enc-zoom-lbl');if(lbl)lbl.textContent=Math.round(ENC.zoom/1.5*100)+'%'; encAutoLayout(); }

