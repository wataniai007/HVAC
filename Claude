/* ============================================================
   INACTIVE PART DETECTION ON PROJECT OPEN
   Scans all canvas objects for inactive parts and
   shows a banner at the top of the schematic view.
   ============================================================ */

function checkAndShowInactiveBanner() {
  const cs = S.canvas || { objects: [] };
  const allParts = typeof getParts === 'function' ? getParts() : [];
  const allCtrls = typeof getControllers === 'function' ? getControllers() : [];
  const allDB    = [...allParts, ...allCtrls];

  const inactive = (cs.objects||[]).filter(obj => {
    const part = allDB.find(p => p.id === (obj.devId||obj.ctrlId));
    return part && part.status === 'inactive';
  });

  const area = document.getElementById('canvas-area') || document.getElementById('ptop-canvas-area');
  const existing = document.getElementById('inactive-banner');
  if (existing) existing.remove();

  if (inactive.length && area) {
    const banner = document.createElement('div');
    banner.id = 'inactive-banner';
    banner.style.cssText = 'position:absolute;top:52px;left:50%;transform:translateX(-50%);background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:8px 16px;font-size:11px;color:#c2410c;z-index:30;display:flex;align-items:center;gap:8px;box-shadow:0 2px 8px rgba(0,0,0,.1);max-width:500px';
    banner.innerHTML = '<span style="font-size:14px">&#9888;</span>'
      + '<span><b>' + inactive.length + ' inactive part(s)</b> found: '
      + inactive.slice(0,4).map(o => '<b>' + o.tag + '</b>').join(', ')
      + (inactive.length > 4 ? ' +' + (inactive.length-4) + ' more' : '')
      + '. These parts are phased out — consider replacing them.</span>'
      + '<button onclick="this.closest(\'#inactive-banner\').remove()" style="background:none;border:none;cursor:pointer;font-size:14px;color:#c2410c;padding:0 2px">&#10005;</button>';
    area.appendChild(banner);
  }
}

/* ============================================================
   POINT NAME BUILDER UI
   Full interactive UI for configuring point names.
   Accessible from the properties panel.
