  if (!warnings.length) {
    html += '<div style="background:#f0fdf4;border:1px solid #6ee7b7;border-radius:8px;padding:20px;text-align:center">';
    html += '<div style="font-size:36px;margin-bottom:8px">&#9989;</div>';
