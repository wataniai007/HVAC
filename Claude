    ctx.fillStyle=obj.color+'20';ctx.strokeStyle=obj.color;ctx.lineWidth=sel?2:1.5;
    ctx.beginPath();ctx.rect(0,0,obj.w,obj.h);ctx.fill();ctx.stroke();
