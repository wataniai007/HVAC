  html += '<div style="display:flex;gap:8px">';
  html += '<button class="btn btn-secondary" onclick="bulkRevise()">&#9656; Bulk Revise Selected</button>';
  html += '<button class="btn btn-primary" onclick="addRevisionToAll()">+ New Revision (All)</button>';
