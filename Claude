function updatePNBPreview(plantName) {
  const sel    = document.getElementById('pnb-tag-sel');
  const custom = document.getElementById('pnb-custom');
  const prev   = document.getElementById('pnb-preview');
  const param  = document.getElementById('pnb-param')?.value || '';
  const tag    = (custom?.value.trim()) || sel?.value || '';
  if (prev) prev.textContent = buildPointName(plantName, param, tag||null);
}

function applyPointName(objId, pi, plantName) {
  const cs  = S.canvas || { objects: [] };
  const obj = (cs.objects||[]).find(o => o.id === objId);
  if (!obj || !obj.points?.[pi]) return;

  const pt     = obj.points[pi];
  const sel    = document.getElementById('pnb-tag-sel');
  const custom = document.getElementById('pnb-custom');
  const param  = document.getElementById('pnb-param')?.value || pt.parameter || '';

  const tag       = (custom?.value.trim()) || sel?.value || '';
  pt._customTag   = custom?.value.trim() || '';
  pt.selectedTag  = tag || null;
  pt.parameter    = param;
  pt.pointName    = buildPointName(plantName, param, tag||null);

  // Range override
  const rmin = document.getElementById('pnb-rmin');
  const rmax = document.getElementById('pnb-rmax');
  if (rmin && rmax && pt.rangeEditable) {
    pt.userRangeMin = parseFloat(rmin.value) || pt.rangeMin;
    pt.userRangeMax = parseFloat(rmax.value) || pt.rangeMax;
  }

  if (typeof addAudit === 'function') addAudit('canvas', 'Point name set: ' + pt.pointName);
  if (typeof saveCS === 'function') saveCS();
  if (typeof closePop === 'function') closePop();
  if (typeof renderPropsPanel === 'function') renderPropsPanel(obj);
  else if (typeof renderProps === 'function') renderProps(obj);
  toast('Point name set: ' + pt.pointName, 'success');
}

