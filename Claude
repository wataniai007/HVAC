/* ============================================================
   PROJECT EXPORT / IMPORT (JSON backup)
   ============================================================ */

function exportProjectJSON() {
  if (!S.project) { toast('No project open', 'error'); return; }

  const exportData = {
    version:      '1.0',
    exportedAt:   new Date().toISOString(),
    exportedBy:   S.user ? S.user.fn + ' ' + S.user.ln : 'Unknown',
    project:      JSON.parse(JSON.stringify(S.project)),
    canvasObjects:JSON.parse(JSON.stringify((S.canvas||{}).objects||[])),
    canvasWires:  JSON.parse(JSON.stringify((S.canvas||{}).wires||[]))
  };

  const blob = new Blob([JSON.stringify(exportData, null, 2)], { type: 'application/json' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = (S.project.num || 'project') + '_export_' + new Date().toISOString().split('T')[0] + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
  toast('Project exported as JSON', 'success');
}

function importProjectJSON() {
  const input = document.createElement('input');
  input.type  = 'file';
  input.accept= '.json';
  input.onchange = function() {
    if (!this.files?.[0]) return;
    const reader = new FileReader();
    reader.onload = function(e) {
      try {
        const data = JSON.parse(e.target.result);
        if (!data.project) { toast('Invalid project file', 'error'); return; }

        const projects = typeof getProjects === 'function' ? getProjects() : [];

        // Check for duplicate
        const existing = projects.find(p => p.id === data.project.id || p.num === data.project.num);
        if (existing) {
          const ok = confirm('A project with this number already exists: "' + existing.name + '". Import as a copy?');
          if (!ok) return;
          data.project.id     = uid('pr');
          data.project.name  += ' (Imported)';
          data.project.num   += '-IMP';
        }

        // Restore canvas objects into project
        if (data.canvasObjects) data.project.objects = data.canvasObjects;
        if (data.canvasWires)   data.project.wires   = data.canvasWires;
        data.project.updatedAt = new Date().toISOString();

        projects.push(data.project);
        if (typeof DB !== 'undefined') DB.set('projects', projects);
        if (typeof renderPL === 'function') renderPL();
        toast('Project imported: ' + data.project.name, 'success');

        // Open it
        setTimeout(() => { if (typeof openProj === 'function') openProj(data.project.id); }, 300);

      } catch(err) {
        toast('Failed to parse project file: ' + err.message, 'error');
      }
    };
    reader.readAsText(this.files[0]);
  };
  input.click();
}

