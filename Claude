/* ── Generic schedule renderer ── */
function renderSchedule(type) {
  const cont = document.getElementById('ucont');
  if (!cont || !S.project) return;

  const def = SCHEDULE_DEFS[type];
  if (!def) return;

  if (!S.project.schedules)       S.project.schedules = {};
  if (!S.project.schedules[type]) S.project.schedules[type] = [];

  const rows = S.project.schedules[type];
  const cols = def.columns;

  let html = `<div style="flex:1;display:flex;flex-direction:column;overflow:hidden">
    <div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
      <div>
        <h3 style="font-size:15px;font-weight:700;color:#0f2744">${def.icon} ${def.label} <span class="badge badge-blue" style="margin-left:6px">${rows.length} rows</span></h3>
        <div class="text-sm text-gray" style="margin-top:2px">
          <span class="badge badge-blue" style="font-size:9px">BMS</span> = BMS contractor responsibility &nbsp;
          <span class="badge badge-gray" style="font-size:9px">Mech</span> = Mechanical contractor (optional)
        </div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-secondary btn-sm" onclick="importScheduleFromClipboard('${type}')">&#8657; Paste from Excel</button>
        <button class="btn btn-secondary btn-sm" onclick="exportSchedulePDF('${type}')">&#128196; Export PDF</button>
        <button class="btn btn-primary btn-sm" onclick="addScheduleRow('${type}')">+ Add Row</button>
      </div>
    </div>
    <div style="flex:1;overflow:auto">
      <table style="border-collapse:collapse;font-size:11px;white-space:nowrap">
        <thead>
          <tr style="background:#1e3a5f;color:#fff;position:sticky;top:0;z-index:10">
            <th style="padding:7px 10px;font-size:9px;font-weight:600;text-align:left;white-space:nowrap">#</th>`;

  cols.forEach(col => {
    const badge = col.bmsOwned
      ? '<span style="background:#2563eb;color:#fff;padding:1px 4px;border-radius:3px;font-size:8px;margin-left:3px">BMS</span>'
      : (col.bmsOwned === false ? '<span style="background:#9ca3af;color:#fff;padding:1px 4px;border-radius:3px;font-size:8px;margin-left:3px">Mech</span>' : '');
    html += `<th style="padding:7px 10px;font-size:9px;font-weight:600;text-align:left;min-width:${col.width}px">${col.label}${badge}</th>`;
  });
  html += `<th style="padding:7px 10px;font-size:9px;font-weight:600"></th></tr></thead><tbody>`;

  if (!rows.length) {
    html += `<tr><td colspan="${cols.length + 2}" style="padding:40px;text-align:center;color:#9ca3af">
      No rows yet. Click + Add Row or paste data from Excel.
    </td></tr>`;
  }

  rows.forEach((row, ri) => {
    const hasError = cols.some(c => c.required && !row[c.key]);
    html += `<tr style="background:${hasError?'#fff5f5':ri%2===0?'#fff':'#f9fafb'}" data-ri="${ri}">`;
    html += `<td style="padding:6px 10px;color:#9ca3af;font-size:10px">${ri+1}</td>`;
    cols.forEach(col => {
      const val  = row[col.key] || '';
      const err  = col.required && !val;
      const style = `padding:4px 8px;${err?'background:#fee2e2;':''}`;
      if (col.editable) {
        html += `<td style="${style}"><input value="${val.toString().replace(/"/g,'&quot;')}"
          onchange="updateScheduleCell('${type}',${ri},'${col.key}',this.value)"
          style="border:none;background:transparent;font:inherit;font-size:11px;width:100%;min-width:${Math.max(50,col.width-20)}px;padding:2px 4px;border-radius:3px"
          onfocus="this.style.background='#eff6ff';this.style.outline='2px solid #2563eb'"
          onblur="this.style.background='transparent';this.style.outline='none'"></td>`;
      } else {
        html += `<td style="${style};color:#6b7280">${val}</td>`;
      }
    });
    html += `<td style="padding:4px 8px"><button onclick="deleteScheduleRow('${type}',${ri})" style="background:none;border:none;cursor:pointer;color:#ef4444;font-size:12px">&#128465;</button></td>`;
    html += '</tr>';
  });

  html += `</tbody></table>
    </div>
  </div>`;

  cont.innerHTML = html;
}

function addScheduleRow(type) {
  if (!S.project) return;
  if (!S.project.schedules) S.project.schedules = {};
  if (!S.project.schedules[type]) S.project.schedules[type] = [];

  const def  = SCHEDULE_DEFS[type];
  const rows = S.project.schedules[type];
  const num  = rows.length + 1;

  // Auto-suggest tag
  const tagPrefixes = { ahu:'AHU', fcu:'FCU', vav:'VAV', valves:'V', dampers:'D', afms:'AF' };
  const pfx = tagPrefixes[type] || type.toUpperCase();
  const newRow = { tag: pfx + '-' + String(num).padStart(2,'0') };

  // Pre-fill controller from canvas if available
  if (S.canvas && (type === 'ahu' || type === 'fcu' || type === 'vav')) {
    const ctrls = (S.canvas.objects||[]).filter(o => o.type === 'controller');
    if (ctrls.length) newRow.controller = ctrls[0].tag;
  }

  rows.push(newRow);
  if (typeof addAudit === 'function') addAudit('schedule', type.toUpperCase() + ' row added: ' + newRow.tag);
  if (typeof saveCS === 'function') saveCS();
  renderSchedule(type);
}

function deleteScheduleRow(type, ri) {
  if (!S.project?.schedules?.[type]) return;
  const row = S.project.schedules[type][ri];
  if (!confirm('Delete row ' + (row?.tag||ri+1) + '?')) return;
  S.project.schedules[type].splice(ri, 1);
  if (typeof addAudit === 'function') addAudit('schedule', type.toUpperCase() + ' row deleted');
  if (typeof saveCS === 'function') saveCS();
  renderSchedule(type);
}

function updateScheduleCell(type, ri, key, val) {
  if (!S.project?.schedules?.[type]) return;
  S.project.schedules[type][ri][key] = val;
  if (typeof saveCS === 'function') saveCS();
  if (typeof addAudit === 'function') addAudit('schedule', 'Cell updated: ' + type + '[' + ri + '].' + key);
}

function importScheduleFromClipboard(type) {
  const raw = prompt('Paste tab-separated data from Excel (first row = headers):');
  if (!raw) return;
  const lines = raw.trim().split('\n').filter(l => l.trim());
  if (lines.length < 2) { toast('Need a header row and at least one data row', 'warning'); return; }

  const def     = SCHEDULE_DEFS[type];
  const headers = lines[0].split('\t').map(h => h.trim().toLowerCase());
  const rows    = lines.slice(1).map(line => {
    const cols = line.split('\t');
    const row  = {};
    def.columns.forEach(col => {
      const hi = headers.findIndex(h => h.includes(col.key.toLowerCase()) || col.label.toLowerCase().includes(h));
      if (hi >= 0 && cols[hi]) row[col.key] = cols[hi].trim();
    });
    return row;
  });

  if (!S.project.schedules)       S.project.schedules = {};
  if (!S.project.schedules[type]) S.project.schedules[type] = [];
  S.project.schedules[type].push(...rows);
  if (typeof addAudit === 'function') addAudit('schedule', rows.length + ' rows imported to ' + type);
  if (typeof saveCS === 'function') saveCS();
  renderSchedule(type);
  toast('Imported ' + rows.length + ' rows', 'success');
}

function exportSchedulePDF(type) {
  const def  = SCHEDULE_DEFS[type];
  const rows = S.project?.schedules?.[type] || [];
  const proj = S.project;
  const win  = window.open('', '_blank');

  win.document.write('<!DOCTYPE html><html><head><title>' + def.label + '</title>'
    + '<style>body{font-family:Arial,sans-serif;font-size:10px;margin:16px}'
    + 'h1{font-size:14px;color:#0f2744}table{width:100%;border-collapse:collapse;margin-top:12px}'
    + 'th{background:#1e3a5f;color:#fff;padding:5px 8px;text-align:left;font-size:9px}'
    + 'td{padding:4px 8px;border-bottom:1px solid #e5e7eb}'
    + '@media print{@page{size:landscape}}'
    + '</style></head><body>');
  win.document.write('<h1>' + def.label + '</h1>');
  win.document.write('<p style="font-size:10px;color:#6b7280">'
    + (proj?.name||'') + ' | ' + (proj?.num||'') + ' | Rev ' + (proj?.rev||'00')
    + ' | ' + new Date().toLocaleDateString() + '</p>');
  win.document.write('<table><thead><tr>');
  def.columns.forEach(c => { win.document.write('<th>' + c.label + '</th>'); });
  win.document.write('</tr></thead><tbody>');
  rows.forEach(row => {
    win.document.write('<tr>');
    def.columns.forEach(c => { win.document.write('<td>' + (row[c.key]||'') + '</td>'); });
    win.document.write('</tr>');
  });
  win.document.write('</tbody></table>');
  win.document.write('<scr'+'ipt>window.onload=function(){window.print();}<\/scr'+'ipt></body></html>');
  win.document.close();
}

