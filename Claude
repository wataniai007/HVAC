<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>HVAC Controls Design Tool</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',sans-serif;background:#0F1929;color:#1F2937;min-height:100vh;display:flex;flex-direction:column;}
.hidden{display:none!important;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border:none;border-radius:6px;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;white-space:nowrap;}
.btn-primary{background:#2563EB;color:#fff;}.btn-primary:hover{background:#1D4ED8;}
.btn-secondary{background:#F3F4F6;color:#374151;border:1px solid #E5E7EB;}.btn-secondary:hover{background:#E5E7EB;}
.btn-danger{background:#FEE2E2;color:#991B1B;border:1px solid #FCA5A5;}
.btn-success{background:#D1FAE5;color:#065F46;border:1px solid #6EE7B7;}
.btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:none;}.btn-ghost:hover{background:rgba(255,255,255,.2);}
.btn-sm{padding:5px 10px;font-size:11px;}.btn-lg{padding:12px 24px;font-size:15px;}
.btn-icon{padding:6px 8px;border-radius:6px;background:none;border:1px solid #E5E7EB;cursor:pointer;color:#6B7280;font-size:13px;}.btn-icon:hover{background:#F3F4F6;}
.w-full{width:100%;}
.form-group{margin-bottom:14px;}
.form-label{display:block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6B7280;margin-bottom:5px;}
.form-input{width:100%;padding:9px 12px;border:1px solid #E5E7EB;border-radius:6px;font-size:13px;color:#1F2937;background:#fff;transition:border .15s;}
.form-input:focus{outline:none;border-color:#2563EB;box-shadow:0 0 0 3px rgba(37,99,235,.1);}
.form-select{width:100%;padding:9px 12px;border:1px solid #E5E7EB;border-radius:6px;font-size:13px;background:#fff;cursor:pointer;}
.form-error{color:#EF4444;font-size:11px;margin-top:3px;}
.form-hint{color:#9CA3AF;font-size:10px;margin-top:3px;}
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:999px;font-size:10px;font-weight:700;}
.badge-blue{background:#DBEAFE;color:#1D4ED8;}.badge-green{background:#D1FAE5;color:#065F46;}
.badge-yellow{background:#FEF3C7;color:#92400E;}.badge-red{background:#FEE2E2;color:#991B1B;}
.badge-purple{background:#EDE9FE;color:#5B21B6;}.badge-orange{background:#FED7AA;color:#9A3412;}
.badge-teal{background:#CCFBF1;color:#0F766E;}.badge-gray{background:#F3F4F6;color:#6B7280;}
.tbl{width:100%;border-collapse:collapse;font-size:12px;}
.tbl th{background:#F8FAFC;padding:9px 12px;text-align:left;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#6B7280;border-bottom:2px solid #E5E7EB;white-space:nowrap;}
.tbl td{padding:10px 12px;border-bottom:1px solid #F3F4F6;color:#374151;vertical-align:middle;}
.tbl tr:hover td{background:#F8FAFC;}.tbl tr:last-child td{border-bottom:none;}
.tbl-wrap{background:#fff;border:1px solid #E5E7EB;border-radius:10px;overflow:hidden;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px;}
.modal-overlay.hidden{display:none!important;}
.modal-box{background:#fff;border-radius:12px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3);}
.modal-sm{max-width:420px;}.modal-md{max-width:580px;}.modal-lg{max-width:760px;}.modal-xl{max-width:960px;}
.modal-header{padding:20px 24px 16px;border-bottom:1px solid #E5E7EB;display:flex;align-items:center;justify-content:space-between;}
.modal-header h2{font-size:17px;font-weight:700;color:#0F1929;}
.modal-body{padding:24px;}.modal-footer{padding:16px 24px;border-top:1px solid #E5E7EB;display:flex;justify-content:flex-end;gap:8px;}
.close-btn{background:none;border:none;font-size:20px;cursor:pointer;color:#9CA3AF;padding:4px;border-radius:4px;line-height:1;}.close-btn:hover{background:#F3F4F6;}
.sidebar{width:220px;background:#0F2744;flex-shrink:0;display:flex;flex-direction:column;overflow:hidden;}
.sidebar-logo{padding:16px;border-bottom:1px solid rgba(255,255,255,.08);}
.sidebar-nav{flex:1;padding:6px 0;overflow-y:auto;}
.nav-section{padding:8px 16px 3px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:rgba(255,255,255,.3);}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 16px;font-size:12px;font-weight:500;color:rgba(255,255,255,.65);cursor:pointer;transition:all .15s;border-left:3px solid transparent;user-select:none;}
.nav-item:hover{background:rgba(255,255,255,.06);color:#fff;}
.nav-item.active{background:rgba(37,99,235,.2);color:#60A5FA;border-left-color:#3B82F6;}
.ni{font-size:14px;width:18px;text-align:center;flex-shrink:0;}
.sidebar-footer{padding:10px 16px;border-top:1px solid rgba(255,255,255,.08);}
.avatar{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
#screen-login{flex:1;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0F1929 0%,#1E3A5F 100%);min-height:100vh;}
.login-card{background:#fff;border-radius:16px;padding:48px;width:100%;max-width:440px;box-shadow:0 24px 64px rgba(0,0,0,.4);}
.login-logo{text-align:center;margin-bottom:32px;}
.login-logo .lg-icon{font-size:52px;display:block;margin-bottom:12px;}
.login-logo h1{font-size:22px;font-weight:700;color:#0F1929;}
.login-logo p{color:#6B7280;font-size:13px;margin-top:4px;}
.login-div{text-align:center;color:#9CA3AF;font-size:11px;margin:16px 0;position:relative;}
.login-div::before,.login-div::after{content:'';position:absolute;top:50%;width:38%;height:1px;background:#E5E7EB;}
.login-div::before{left:0;}.login-div::after{right:0;}
.demo-btn{padding:10px 14px;border:1px solid #E5E7EB;border-radius:8px;cursor:pointer;background:#F9FAFB;transition:all .15s;text-align:left;width:100%;margin-bottom:6px;display:block;}
.demo-btn:hover{border-color:#2563EB;background:#EFF6FF;}
.demo-role{font-size:11px;font-weight:700;color:#2563EB;text-transform:uppercase;letter-spacing:.5px;}
.demo-email{font-size:12px;color:#374151;margin-top:2px;}
#screen-launch{flex:1;display:flex;flex-direction:column;min-height:100vh;background:#F0F4F8;}
.lhdr{background:#0F2744;padding:0 32px;height:56px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.lhdr h1{color:#fff;font-size:15px;font-weight:700;}
.lbody{flex:1;padding:32px;overflow-y:auto;max-width:1200px;margin:0 auto;width:100%;}
.launch-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px;}
.acard{background:#fff;border:2px solid #E5E7EB;border-radius:12px;padding:24px;cursor:pointer;transition:all .15s;display:flex;align-items:flex-start;gap:16px;}
.acard:hover{border-color:#2563EB;box-shadow:0 4px 20px rgba(37,99,235,.12);transform:translateY(-1px);}
.acard.primary{border-color:#2563EB;background:#EFF6FF;}
.ac-icon{font-size:32px;flex-shrink:0;}
.ac-title{font-size:15px;font-weight:700;color:#0F2744;margin-bottom:4px;}
.ac-desc{font-size:12px;color:#6B7280;line-height:1.5;}
.proj-row{display:flex;align-items:center;gap:12px;padding:14px 16px;background:#fff;border:1px solid #E5E7EB;border-radius:10px;margin-bottom:8px;cursor:pointer;transition:all .15s;}
.proj-row:hover{border-color:#2563EB;box-shadow:0 2px 12px rgba(37,99,235,.08);}
.proj-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.proj-name{font-size:14px;font-weight:600;color:#0F2744;margin-bottom:2px;}
.proj-meta{font-size:11px;color:#9CA3AF;display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.sbar{display:flex;gap:8px;margin-bottom:12px;}
.sinput{flex:1;padding:9px 14px;border:1px solid #E5E7EB;border-radius:8px;font-size:13px;background:#fff;}
.sinput:focus{outline:none;border-color:#2563EB;}
.fsel{padding:9px 12px;border:1px solid #E5E7EB;border-radius:8px;font-size:12px;background:#fff;}
.empty{text-align:center;padding:56px 24px;color:#9CA3AF;}
#screen-app{flex:1;display:flex;flex-direction:column;min-height:100vh;}
.atop{background:#0F2744;height:48px;display:flex;align-items:center;padding:0 16px;gap:10px;flex-shrink:0;}
.atop h1{color:#fff;font-size:13px;font-weight:700;max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.ttab{background:rgba(255,255,255,.08);border:none;color:rgba(255,255,255,.7);padding:5px 12px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;}
.ttab:hover{background:rgba(255,255,255,.15);color:#fff;}.ttab.active{background:#2563EB;color:#fff;}
.tsep{width:1px;height:20px;background:rgba(255,255,255,.15);}
.pchip{background:rgba(255,255,255,.08);padding:4px 10px;border-radius:999px;font-size:10px;font-weight:700;color:rgba(255,255,255,.8);}
.abody{flex:1;display:flex;overflow:hidden;}
.acont{flex:1;display:flex;flex-direction:column;overflow:hidden;background:#F0F4F8;}
.actop{background:#fff;border-bottom:1px solid #E5E7EB;padding:0 24px;height:52px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.actop h2{font-size:15px;font-weight:700;color:#0F2744;}
.amain{flex:1;padding:24px;overflow-y:auto;}
.sgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.scard{background:#fff;border:1px solid #E5E7EB;border-radius:10px;padding:16px 18px;position:relative;}
.sv{font-size:28px;font-weight:700;color:#0F2744;}.sl{font-size:11px;color:#9CA3AF;margin-top:4px;text-transform:uppercase;letter-spacing:.5px;}
.si{position:absolute;top:14px;right:16px;font-size:22px;}
.pgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px;}
.pcard{background:#fff;border:1px solid #E5E7EB;border-radius:12px;overflow:hidden;}
.pc-hdr{padding:16px 20px 12px;display:flex;align-items:center;gap:12px;border-bottom:1px solid #F3F4F6;}
.pc-dot{width:12px;height:12px;border-radius:50%;}
.pc-body{padding:14px 20px;}
.pcr{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid #F9FAFB;font-size:12px;}
.pcr:last-child{border-bottom:none;}
.pcrl{color:#9CA3AF;font-size:11px;}.pcrv{font-weight:600;color:#374151;}
.pc-ftr{padding:10px 20px;background:#F9FAFB;display:flex;gap:6px;justify-content:flex-end;}
.wiz{display:flex;align-items:center;margin-bottom:28px;}
.ws{display:flex;align-items:center;gap:8px;}
.wsn{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;background:#E5E7EB;color:#9CA3AF;flex-shrink:0;transition:all .2s;}
.ws.active .wsn{background:#2563EB;color:#fff;}.ws.done .wsn{background:#10B981;color:#fff;}
.wsl{font-size:12px;font-weight:600;color:#9CA3AF;white-space:nowrap;}
.ws.active .wsl{color:#2563EB;}.ws.done .wsl{color:#10B981;}
.wcon{flex:1;height:2px;background:#E5E7EB;margin:0 8px;transition:background .2s;}.wcon.done{background:#10B981;}
.psg{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;}
.psc{border:2px solid #E5E7EB;border-radius:10px;padding:16px;cursor:pointer;transition:all .15s;background:#fff;}
.psc:hover{border-color:#93C5FD;background:#F0F7FF;}
.psc.sel{border-color:#2563EB;background:#EFF6FF;box-shadow:0 0 0 3px rgba(37,99,235,.15);}
.psc-ico{font-size:28px;margin-bottom:8px;}.psc-name{font-size:14px;font-weight:700;color:#0F2744;margin-bottom:5px;}
.psc-det{font-size:10px;color:#6B7280;line-height:1.6;}
.csoon{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#F8FAFC;color:#9CA3AF;gap:14px;padding:48px;}
.csoon-ico{font-size:60px;}.csoon h3{font-size:18px;font-weight:700;color:#374151;}
.csoon p{font-size:13px;text-align:center;max-width:400px;line-height:1.6;}
.ctags{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-top:4px;}
.chdr,.crow{display:grid;grid-template-columns:80px 70px 1fr 110px 32px;gap:8px;padding:7px 12px;align-items:center;font-size:12px;}
.chdr{background:#F8FAFC;font-size:10px;font-weight:700;text-transform:uppercase;color:#9CA3AF;border-bottom:1px solid #E5E7EB;}
.crow{border-bottom:1px solid #F3F4F6;}.crow:last-child{border-bottom:none;}
.ptrow{padding:12px;border-bottom:1px solid #F3F4F6;font-size:12px;}.ptrow:last-child{border-bottom:none;}
.audit-row{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid #F3F4F6;font-size:12px;}
.audit-row:last-child{border-bottom:none;}
.audit-time{color:#9CA3AF;font-size:10px;white-space:nowrap;min-width:120px;}
.audit-user{font-weight:600;color:#374151;min-width:100px;}
.audit-action{color:#6B7280;flex:1;line-height:1.4;}
.audit-cat{padding:1px 6px;border-radius:4px;font-size:9px;font-weight:700;text-transform:uppercase;white-space:nowrap;}
.ac-canvas{background:#DBEAFE;color:#1D4ED8;}.ac-settings{background:#FEF3C7;color:#92400E;}
.ac-access{background:#FEE2E2;color:#991B1B;}.ac-schedule{background:#D1FAE5;color:#065F46;}
.ref-item{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;background:#F9FAFB;border:1px solid #E5E7EB;border-radius:6px;margin-bottom:4px;font-size:12px;}
.cdot{width:26px;height:26px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:all .15s;}
.cdot.sel{border-color:#111827;transform:scale(1.1);}
.lib-panel{width:210px;background:#fff;border-right:1px solid #E5E7EB;display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
.lib-search-box{padding:8px;border-bottom:1px solid #E5E7EB;}
.lib-search-box input{width:100%;padding:6px 10px;border:1px solid #E5E7EB;border-radius:6px;font-size:11px;}
.lib-tree{flex:1;overflow-y:auto;}
.lib-lib-hdr{display:flex;align-items:center;gap:6px;padding:8px 10px;font-size:11px;font-weight:700;color:#374151;cursor:pointer;user-select:none;background:#F8FAFC;border-bottom:1px solid #E5E7EB;border-top:1px solid #E5E7EB;margin-top:4px;}
.lib-lib-hdr:first-child{margin-top:0;border-top:none;}
.lib-lib-hdr:hover{background:#EFF6FF;}
.lib-cat-hdr{display:flex;align-items:center;gap:5px;padding:5px 14px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#9CA3AF;cursor:pointer;user-select:none;}
.lib-cat-hdr:hover{color:#374151;}
.lib-item{display:flex;align-items:center;gap:7px;padding:6px 20px;font-size:11px;color:#374151;cursor:grab;transition:background .1s;user-select:none;}
.lib-item:hover{background:#EFF6FF;color:#1D4ED8;}
.lib-sym{font-size:14px;width:18px;text-align:center;flex-shrink:0;}
.canvas-wrap{flex:1;position:relative;overflow:hidden;background:#F8FAFC;}
#main-canvas{display:block;cursor:default;}
.canvas-toolbar{position:absolute;top:10px;left:50%;transform:translateX(-50%);background:#fff;border:1px solid #E5E7EB;border-radius:8px;padding:4px;display:flex;gap:2px;z-index:10;box-shadow:0 2px 8px rgba(0,0,0,.1);}
.ct-btn{background:none;border:none;padding:5px 10px;border-radius:5px;cursor:pointer;font-size:11px;color:#374151;transition:background .1s;}
.ct-btn:hover{background:#F3F4F6;}.ct-btn.active{background:#EFF6FF;color:#1D4ED8;}
.zoom-ctrl{position:absolute;bottom:36px;right:12px;background:#fff;border:1px solid #E5E7EB;border-radius:6px;display:flex;flex-direction:column;overflow:hidden;}
.z-btn{background:none;border:none;padding:6px 10px;cursor:pointer;font-size:14px;}.z-btn:hover{background:#F3F4F6;}
.z-lbl{font-size:9px;text-align:center;padding:2px;color:#9CA3AF;border-top:1px solid #E5E7EB;border-bottom:1px solid #E5E7EB;}
.props-panel{width:250px;background:#fff;border-left:1px solid #E5E7EB;display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;}
.props-hdr{padding:10px 12px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:#6B7280;border-bottom:1px solid #E5E7EB;}
.props-body{flex:1;overflow-y:auto;padding:10px;}
.prop-sec{margin-bottom:12px;}
.prop-sec-title{font-size:10px;font-weight:700;text-transform:uppercase;color:#9CA3AF;margin-bottom:5px;display:flex;align-items:center;gap:5px;}
.prop-sec-title::after{content:'';flex:1;height:1px;background:#F3F4F6;}
.checklist-item{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid #F9FAFB;font-size:11px;}
.checklist-item:last-child{border-bottom:none;}
.ci-ico{font-size:14px;flex-shrink:0;width:16px;text-align:center;}
.ci-lbl{flex:1;color:#374151;}
.ci-act{font-size:10px;color:#2563EB;cursor:pointer;white-space:nowrap;}.ci-act:hover{text-decoration:underline;}
.sb-bar{background:#0F2744;color:rgba(255,255,255,.65);height:26px;display:flex;align-items:center;padding:0 16px;font-size:10px;gap:16px;flex-shrink:0;}
.sb-dot{width:6px;height:6px;border-radius:50%;background:#10B981;display:inline-block;margin-right:4px;}
.sb-dot.warn{background:#F59E0B;}.sb-dot.err{background:#EF4444;}
#tw{position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;pointer-events:none;}
.toast{background:#1F2937;color:#fff;padding:12px 16px;border-radius:8px;font-size:12px;font-weight:500;box-shadow:0 4px 16px rgba(0,0,0,.3);display:flex;align-items:center;gap:8px;min-width:220px;animation:tIn .2s ease;}
.toast.success{background:#065F46;border-left:3px solid #10B981;}
.toast.error{background:#991B1B;border-left:3px solid #EF4444;}
.toast.warning{background:#92400E;border-left:3px solid #F59E0B;}
.toast.info{background:#1E3A5F;border-left:3px solid #3B82F6;}
@keyframes tIn{from{transform:translateX(60px);opacity:0;}to{transform:translateX(0);opacity:1;}}
#cw{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:2000;display:flex;align-items:center;justify-content:center;}
#cw.hidden{display:none!important;}
.cbox{background:#fff;border-radius:12px;padding:24px;max-width:380px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.3);}
.cbox h3{font-size:16px;font-weight:700;margin-bottom:8px;color:#0F1929;}
.cbox p{font-size:13px;color:#6B7280;line-height:1.5;margin-bottom:20px;}
::-webkit-scrollbar{width:5px;height:5px;}::-webkit-scrollbar-track{background:#F3F4F6;}::-webkit-scrollbar-thumb{background:#D1D5DB;border-radius:3px;}
</style>
</head>
<body>

<div id="screen-login">
<div class="login-card">
  <div class="login-logo"><span class="lg-icon">⚡</span><h1>HVAC Controls Design</h1><p>Professional BMS Engineering Tool</p></div>
  <div class="form-group"><label class="form-label">Email</label><input class="form-input" id="li-email" type="email" value="admin@hvac.com" onkeydown="if(event.key==='Enter')doLogin()"></div>
  <div class="form-group"><label class="form-label">Password</label><input class="form-input" id="li-pw" type="password" value="password" onkeydown="if(event.key==='Enter')doLogin()"></div>
  <div id="li-err" class="form-error hidden" style="margin-bottom:10px;"></div>
  <button class="btn btn-primary w-full btn-lg" onclick="doLogin()" style="margin-bottom:16px;">Sign In →</button>
  <div class="login-div">quick login</div>
  <button class="demo-btn" onclick="ql('admin@hvac.com')"><div class="demo-role">🔧 Admin</div><div class="demo-email">admin@hvac.com · Full access both sides</div></button>
  <button class="demo-btn" onclick="ql('engineer@hvac.com')"><div class="demo-role">📐 Engineer</div><div class="demo-email">engineer@hvac.com · Design access</div></button>
  <button class="demo-btn" onclick="ql('reviewer@hvac.com')"><div class="demo-role">✅ Reviewer</div><div class="demo-email">reviewer@hvac.com · View and comment</div></button>
</div>
</div>

<div id="screen-launch" class="hidden" style="flex:1;display:flex;flex-direction:column;min-height:100vh;">
<div class="lhdr">
  <h1>⚡ HVAC Controls Design Tool</h1>
  <div style="display:flex;align-items:center;gap:10px;">
