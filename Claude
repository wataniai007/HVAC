function downloadBulkTemplate() {
  const templates = {
    devices:     'Manufacturer\tModel\tDescription\tCategory\tMounting\tStatus\tHelpText\tDatasheetURL\n' +
                 'Honeywell\tC7041B2005\tDuct Temp Sensor\tSensor\tDuct\tactive\t20kOhm NTC sensor\t[...](https://...\n)',
    controllers: 'Manufacturer\tModel\tSeries\tProtocol\tPowerSupply\tOperatingTemp\tEnclosure\n' +
                 'Honeywell\tCPO-PC400\tComfortPoint Open\tBACnet/IP\t24 Vac\t0 to 50C\tIP20\n',
    suppliers:   'Name\tLeadTimeDays\tCurrency\tNotes\n' +
                 'Kele & Associates\t7\tUSD\tStock distributor\n',
    pointNames:  'Parameter\tCategory\tTag\tDescription\n' +
                 'Duct_Temperature\tTemperature\tDaTemp\tDischarge Air Temperature\n'
  };
  const content = templates[_bulkImportType] || templates.devices;
  const blob = new Blob([content], { type: 'text/tab-separated-values' });
  const a    = document.createElement('a');
  a.href     = URL.createObjectURL(blob);
  a.download = _bulkImportType + '_import_template.tsv';
  a.click();
  toast('Template downloaded', 'success');
}

function handleBulkFile(input) {
  if (!input.files?.[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    const area = document.getElementById('bulk-paste-area');
    if (area) area.value = e.target.result;
    parseBulkPaste();
  };
  reader.readAsText(input.files[0]);
}

function parseBulkPaste() {
  const raw = (document.getElementById('bulk-paste-area')?.value||'').trim();
  if (!raw) { toast('No data to parse', 'warning'); return; }

  const lines   = raw.split('\n').map(l => l.trim()).filter(l => l && !l.startsWith('//'));
  if (lines.length < 2) { toast('Need at least a header row and one data row', 'warning'); return; }

  _bulkImportHeaders = lines[0].split('\t').map(h => h.trim().toLowerCase());
  _bulkImportRows = lines.slice(1).map((line, i) => {
    const cols = line.split('\t');
    const row  = {};
    _bulkImportHeaders.forEach((h, j) => { row[h] = (cols[j]||'').trim(); });

    // Validation
    const hasModel = row.model || row.name;
    const hasMfr   = row.manufacturer || row.mfr;
    row._line  = i + 2;
    row._valid = !!(hasModel || row.parameter); // parameter for pointNames
    row._error = row._valid ? '' : 'Missing required fields';

    // Duplicate detection
    const allParts = typeof getParts === 'function' ? getParts() : [];
    if (row.model && allParts.find(p => p.model?.toLowerCase() === row.model.toLowerCase())) {
      row._duplicate = true;
      row._warn = 'Already exists in database (will update if imported)';
    }

    return row;
  });

  renderBulkPreview();
}

function renderBulkPreview() {
  const el = document.getElementById('bulk-preview-inner');
  if (!el) return;

  const valid   = _bulkImportRows.filter(r => r._valid);
  const invalid = _bulkImportRows.filter(r => !r._valid);
  const dups    = _bulkImportRows.filter(r => r._duplicate);

  let html = '<div style="display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap">';
  html += '<span class="badge badge-green">' + valid.length + ' valid</span>';
  if (invalid.length) html += '<span class="badge badge-red">' + invalid.length + ' errors</span>';
  if (dups.length)    html += '<span class="badge badge-yellow">' + dups.length + ' duplicates</span>';
  html += '</div>';

  html += '<div style="max-height:300px;overflow-y:auto"><div class="tbl-wrap"><table class="tbl"><thead><tr>';
  html += '<th>Row</th><th>Status</th>';
  _bulkImportHeaders.slice(0,5).forEach(h => { html += '<th>' + h + '</th>'; });
  html += '</tr></thead><tbody>';

  _bulkImportRows.forEach(r => {
    const statusBadge = r._valid
      ? (r._duplicate
          ? '<span class="badge badge-yellow" style="font-size:9px">Update</span>'
          : '<span class="badge badge-green" style="font-size:9px">&#10003; Valid</span>')
      : '<span class="badge badge-red" style="font-size:9px">&#10005; ' + r._error + '</span>';

    html += '<tr style="background:' + (!r._valid?'#fff5f5':r._duplicate?'#fffbeb':'#fff') + '">';
    html += '<td class="text-sm text-gray">' + r._line + '</td>';
    html += '<td>' + statusBadge + '</td>';
    _bulkImportHeaders.slice(0,5).forEach(h => {
      html += '<td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px">' + (r[h]||'') + '</td>';
    });
    html += '</tr>';
  });

  html += '</tbody></table></div></div>';

  if (valid.length) {
    const btn = document.getElementById('bulk-commit-btn');
    if (btn) {
      btn.style.display = '';
      btn.textContent   = 'Import ' + valid.length + ' Row' + (valid.length !== 1 ? 's' : '');
    }
  }

  el.innerHTML = html;
}

function commitBulkImport() {
  const valid = _bulkImportRows.filter(r => r._valid);
  if (!valid.length) return;

  let added = 0, updated = 0;

  if (_bulkImportType === 'devices') {
    const parts = typeof getParts === 'function' ? getParts() : [];
    valid.forEach(r => {
      const model = r.model || '';
      const mfr   = r.manufacturer || r.mfr || '';
      const existing = parts.find(p => p.model?.toLowerCase() === model.toLowerCase());
      const obj = {
        id:           existing?.id || uid('d'),
        manufacturer: mfr, model,
        description:  r.description || r.desc || '',
        category:     r.category    || 'Sensor',
        mounting:     r.mounting    || 'Duct',
        status:       r.status      || 'active',
        helpText:     r.helptext    || r.help || '',
        datasheetUrl: r.datasheeturl|| r.url  || '',
        scopeOfSupply:'Supplied by Business',
        poles:        [], points: [], suppliers: [],
        accessories:  [], uplinkPorts: [], pseudoPoints: [],
        widthMm:0, heightMm:0, dinUnits:0,
        createdAt:    existing?.createdAt || now(),
        updatedAt:    now()
      };
      if (existing) { const idx=parts.findIndex(p=>p.id===existing.id); parts[idx]=obj; updated++; }
      else { parts.push(obj); added++; }
    });
    if (typeof saveParts === 'function') saveParts(parts);

  } else if (_bulkImportType === 'suppliers') {
    const sups = typeof getSuppliers === 'function' ? getSuppliers() : [];
    valid.forEach(r => {
      const name = r.name || '';
      if (!name) return;
      const existing = sups.find(s => s.name.toLowerCase() === name.toLowerCase());
      if (!existing) {
        sups.push({ id:uid('s'), name, leadTimeDays:parseInt(r.leadtimedays)||14, currency:r.currency||'USD', notes:r.notes||'', contact:'' });
        added++;
      }
    });
    if (typeof DB !== 'undefined') DB.set('suppliers', sups);

  } else if (_bulkImportType === 'pointNames') {
    const pns = typeof getPointNames === 'function' ? getPointNames() : [];
    valid.forEach(r => {
      const param = r.parameter || '';
      const tag   = r.tag || '';
      const desc  = r.description || '';
      const cat   = r.category || 'General';
      if (!param) return;
      let pn = pns.find(p => p.parameter === param);
      if (!pn) { pn = { id:uid('pn'), parameter:param, category:cat, tags:[], pseudoPoints:[] }; pns.push(pn); }
      if (tag && !pn.tags.find(t => t.tag === tag)) { pn.tags.push({ tag, description:desc }); added++; }
    });
    if (typeof DB !== 'undefined') DB.set('point-names', pns);
  }

  if (typeof DB !== 'undefined' && _bulkImportType === 'devices') {
    // Already saved above via saveParts
  }

  toast('Imported ' + added + ' new, updated ' + updated + ' existing ' + _bulkImportType, 'success');
  _bulkImportRows = [];

  const commitBtn = document.getElementById('bulk-commit-btn');
  if (commitBtn) commitBtn.style.display = 'none';
  const previewEl = document.getElementById('bulk-preview-inner');
  if (previewEl) previewEl.innerHTML = '<div style="background:#f0fdf4;border:1px solid #6ee7b7;border-radius:6px;padding:12px;font-size:12px;color:#065f46">&#10003; Import complete — ' + added + ' added, ' + updated + ' updated</div>';
}

