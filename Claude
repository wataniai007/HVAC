function snap(v,g=10){return Math.round(v/g)*g;}
function toWorld(cx,cy){return{wx:(cx-S.canvasState.pan.x)/S.canvasState.zoom,wy:(cy-S.canvasState.pan.y)/S.canvasState.zoom};}
function hitTest(wx,wy){
