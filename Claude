    html += '<label class="form-check" style="font-size:11px"><input type="checkbox" id="rev-sel-all" onclick="document.querySelectorAll(\'.rev-sheet-chk\').forEach(c=>c.checked=this.checked)"> Select All</label>';
    html += '</div>';

    html += '<div class="tbl-wrap"><table class="tbl"><thead><tr>';
    html += '<th style="width:30px"></th><th>Sheet #</th><th>Title</th><th>Current Rev</th><th>Last Action</th><th>History</th>';
    html += '</tr></thead><tbody>';

    sheets.forEach((sh, i) => {
      const revs    = sh.revisions || [];
      const lastRev = revs[revs.length - 1];
      html += `<tr>
        <td><input type="checkbox" class="rev-sheet-chk" value="${i}"></td>
        <td><b>${sh.number}</b></td>
