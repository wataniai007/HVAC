    ctx.fillStyle='#fff';ctx.strokeStyle=sel?'#2563EB':bc;ctx.lineWidth=sel?2.5:2;
    ctx.beginPath();ctx.arc(obj.w/2,obj.h/2,r,0,Math.PI*2);ctx.fill();ctx.stroke();
