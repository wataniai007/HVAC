        html += '<div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:10px 14px;margin-bottom:7px;display:flex;align-items:flex-start;gap:10px;cursor:' + (action?'pointer':'default') + '" ' + action + '>';
