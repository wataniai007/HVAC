function showS(n){['login','launch','app'].forEach(s=>{const e=document.getElementById('screen-'+s);if(e)e.classList.toggle('hidden',s!==n)});}

function doLogin(){
  const email=document.getElementById('li-email').value.trim();
  const pw=document.getElementById('li-pw').value;
  const u=(DB.get('users')||[]).find(x=>x.email===email&&x.pw===pw&&x.status==='Active');
  const err=document.getElementById('li-err');
  if(!u){err.textContent='Invalid email or password';err.classList.remove('hidden');return;}
  err.classList.add('hidden');S.user=u;afterLogin();
}
function ql(e){document.getElementById('li-email').value=e;document.getElementById('li-pw').value='password';doLogin();}
function afterLogin(){
  const u=S.user;
  document.getElementById('lh-name').textContent=u.fn+' '+u.ln;
  const rb=document.getElementById('lh-role');rb.textContent=u.role;rb.className='badge '+(u.role==='Admin'?'badge-purple':u.role==='Reviewer'?'badge-green':'badge-blue');
  document.getElementById('lh-greet').textContent=greet()+', '+u.fn+'!';
  document.getElementById('lh-adm').style.display=u.role==='Admin'?'':'none';
  document.getElementById('sb-name').textContent=u.fn+' '+u.ln;
  document.getElementById('sb-role').textContent=u.role;
  document.getElementById('sb-av').textContent=u.fn[0]+u.ln[0];
  document.getElementById('adm-name').textContent=u.fn+' '+u.ln;
  document.getElementById('adm-av').textContent=u.fn[0]+u.ln[0];
  document.getElementById('tab-a').style.display=u.role==='Admin'?'':'none';
  fillFilters();renderPL();showS('launch');toast('Welcome back, '+u.fn+'!','success');
}
