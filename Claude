            ${revs.length>1?'<button onclick="deleteLastRevision('+i+')" style="background:none;border:1px solid #e5e7eb;border-radius:3px;cursor:pointer;font-size:10px;padding:1px 5px;color:#ef4444">&#8722;Rev</button>':''}
          </div>
