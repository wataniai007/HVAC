/* ============================================================
   SYSTEM ARCHITECTURE SCHEDULE
   Auto-generated table showing all controllers, their
   bus connections, parent/child relationships, locations,
   and I/O channel counts
   ============================================================ */

function renderArchitectureSchedule() {
  const cont = document.getElementById('ucont');
  if (!cont || !S.project) return;

  const cs = S.canvas || { objects: [] };
  const ctrls = (cs.objects||[]).filter(o => o.type === 'controller');

  if (!ctrls.length) {
    cont.innerHTML = '<div class="csoon"><span class="csoon-ico">&#127759;</span><h3>System Architecture Schedule</h3><p>Add controllers to the schematic canvas. This schedule auto-generates from controller assignments, locations, and parent-channel relationships.</p></div>';
    return;
  }

  let html = '<div style="flex:1;overflow:auto;padding:20px">';
  html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">';
  html += '<h3 style="font-size:15px;font-weight:700;color:#0f2744">System Architecture Schedule <span class="badge badge-blue" style="margin-left:6px">' + ctrls.length + ' controllers</span></h3>';
  html += '<button class="btn btn-secondary btn-sm" onclick="exportArchSchedulePDF()">&#128196; Export PDF</button>';
  html += '</div>';

  html += '<div class="tbl-wrap"><table class="tbl"><thead><tr>'
    + '<th>Tag</th><th>Model</th><th>Role</th><th>Location</th>'
    + '<th>Parent / Bus</th><th>Protocol</th>'
    + '<th>AI</th><th>AO</th><th>DI</th><th>DO</th><th>Total</th>'
    + '<th>Assigned</th><th>Spare</th>'
    + '</tr></thead><tbody>';

  ctrls.forEach(ctrl => {
    const chs     = ctrl.channels || [];
    const ai      = chs.filter(c => c.cls === 'AI').length;
    const ao      = chs.filter(c => c.cls === 'AO').length;
    const di      = chs.filter(c => c.cls === 'DI').length;
    const doo     = chs.filter(c => c.cls === 'DO').length;
    const total   = chs.length;
    const assigned= chs.filter(c => c.assigned).length;
    const spare   = total - assigned;

    const isRoot  = !ctrl.parentCtrl;
    const showRiser = ctrl.showOnRiser !== false;

    html += '<tr style="background:' + (isRoot ? '#eff6ff' : '#fff') + '">'
      + '<td><b>' + (ctrl.tag||'—') + '</b>' + (isRoot ? ' <span class="badge badge-blue" style="font-size:8px">Root</span>' : '') + '</td>'
      + '<td>' + (ctrl.model||'—') + '</td>'
      + '<td><span class="badge badge-gray" style="font-size:9px">' + (ctrl.role||ctrl.model||'Controller') + '</span></td>'
      + '<td style="font-size:10px;color:#6b7280">' + (ctrl.location||'—') + '</td>'
      + '<td style="font-size:10px">' + (ctrl.parentCtrl||'—') + '</td>'
      + '<td style="font-size:10px;color:#6b7280">' + (ctrl.proto||ctrl.protocol||'BACnet') + '</td>'
      + '<td style="text-align:center;color:#1d4ed8;font-weight:600">' + ai  + '</td>'
      + '<td style="text-align:center;color:#065f46;font-weight:600">' + ao  + '</td>'
      + '<td style="text-align:center;color:#92400e;font-weight:600">' + di  + '</td>'
      + '<td style="text-align:center;color:#991b1b;font-weight:600">' + doo + '</td>'
      + '<td style="text-align:center;font-weight:700">' + total + '</td>'
      + '<td style="text-align:center;color:#065f46">' + assigned + '</td>'
      + '<td style="text-align:center;color:' + (spare < 2 ? '#dc2626' : '#6b7280') + '">' + spare + '</td>'
      + '</tr>';
  });

  html += '</tbody></table></div>';

  // Summary totals
  const totAI  = ctrls.reduce((n,c)=>n+(c.channels||[]).filter(ch=>ch.cls==='AI').length, 0);
  const totAO  = ctrls.reduce((n,c)=>n+(c.channels||[]).filter(ch=>ch.cls==='AO').length, 0);
  const totDI  = ctrls.reduce((n,c)=>n+(c.channels||[]).filter(ch=>ch.cls==='DI').length, 0);
  const totDO  = ctrls.reduce((n,c)=>n+(c.channels||[]).filter(ch=>ch.cls==='DO').length, 0);
  const totAll = totAI + totAO + totDI + totDO;
  const totAsgn= ctrls.reduce((n,c)=>n+(c.channels||[]).filter(ch=>ch.assigned).length, 0);

  html += '<div style="display:grid;grid-template-columns:repeat(6,1fr);gap:10px;margin-top:14px">';
  [['AI', totAI, '#dbeafe','#1d4ed8'], ['AO', totAO, '#dcfce7','#065f46'], ['DI', totDI, '#fef9c3','#92400e'], ['DO', totDO, '#fee2e2','#991b1b'], ['Total', totAll, '#f3f4f6','#374151'], ['Assigned', totAsgn, '#f0fdf4','#065f46']].forEach(([lbl,val,bg,col]) => {
    html += '<div style="background:'+bg+';border-radius:8px;padding:10px;text-align:center"><div style="font-size:22px;font-weight:700;color:'+col+'">'+val+'</div><div style="font-size:10px;color:#6b7280;text-transform:uppercase;letter-spacing:.5px">'+lbl+'</div></div>';
  });
  html += '</div></div>';

  cont.innerHTML = html;
}

