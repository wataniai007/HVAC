}

function addRevisionToSheet(si) {
  if (!S.project?.sheets?.[si]) return;
  const rev = prompt('Revision number/letter:', nextRevLabel(S.project.sheets[si]));
  if (!rev) return;
  const desc = prompt('Description:', 'Issued for Review');
  if (!desc) return;
  if (!S.project.sheets[si].revisions) S.project.sheets[si].revisions = [];
  S.project.sheets[si].revisions.push({ rev, date: new Date().toISOString(), description: desc, by: S.user ? S.user.fn + ' ' + S.user.ln : '' });
  if (typeof addAudit === 'function') addAudit('canvas', 'Revision ' + rev + ' added to sheet ' + S.project.sheets[si].number);
  if (typeof saveCS === 'function') saveCS();
  renderRevisionManager();
  toast('Revision added to sheet ' + S.project.sheets[si].number, 'success');
}

function deleteLastRevision(si) {
  if (!S.project?.sheets?.[si]?.revisions?.length) return;
  if (S.project.sheets[si].revisions.length <= 1) { toast('Cannot delete the only revision', 'error'); return; }
  if (!confirm('Delete the last revision from sheet ' + S.project.sheets[si].number + '?')) return;
  S.project.sheets[si].revisions.pop();
  if (typeof saveCS === 'function') saveCS();
  renderRevisionManager();
  toast('Last revision deleted', 'warning');
}

function bulkRevise() {
  const selected = [...document.querySelectorAll('.rev-sheet-chk:checked')].map(c => parseInt(c.value));
  if (!selected.length) { toast('Select at least one sheet first', 'warning'); return; }
  const rev  = prompt('Revision number/letter for all selected sheets:', 'A');
  if (!rev) return;
  const desc = prompt('Revision description:', 'Issued for Review');
  if (!desc) return;
  const by = S.user ? S.user.fn + ' ' + S.user.ln : '';
  selected.forEach(si => {
    if (!S.project.sheets[si]) return;
    if (!S.project.sheets[si].revisions) S.project.sheets[si].revisions = [];
    S.project.sheets[si].revisions.push({ rev, date: new Date().toISOString(), description: desc, by });
  });
  if (typeof addAudit === 'function') addAudit('canvas', 'Bulk revision ' + rev + ' applied to ' + selected.length + ' sheets');
  if (typeof saveCS === 'function') saveCS();
  renderRevisionManager();
  toast('Revision ' + rev + ' applied to ' + selected.length + ' sheets', 'success');
}

function addRevisionToAll() {
  document.querySelectorAll('.rev-sheet-chk').forEach(c => c.checked = true);
  bulkRevise();
}

function nextRevLabel(sheet) {
  const revs = sheet.revisions || [];
  if (!revs.length) return 'A';
  const last = revs[revs.length - 1].rev;
  const num = parseInt(last);
  if (!isNaN(num)) return String(num + 1).padStart(2, '0');
  const code = last.charCodeAt(0);
  return String.fromCharCode(code + 1);
}

