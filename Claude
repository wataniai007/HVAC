    selSheets.forEach(sh => {
      const lastRev = sh.revisions?.slice(-1)[0];
      win.document.write('<tr><td><b>'+sh.number+'</b></td><td>'+sh.title+'</td><td>'+sh.type+'</td><td>'+sh.size+'</td><td>'+lastRev?.rev+'</td></tr>');
