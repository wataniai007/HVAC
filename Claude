    points: [{
      id:          uid('gpt'),
      role:        ioClass + ' Point',
      tagPrefix:   prefix,
      instanceTag: tag,
      pointName:   (S.project.systems?.[0]?.plants?.[0]?.name || 'PLANT') + '_' + tag,
      signalType:  ioClass === 'AI' ? '0-10VDC' : ioClass === 'AO' ? '0-10VDC' : 'Dry Contact',
      ioClass,
      rangeMin: 0, rangeMax: 100, rangeUnit: '',
      rangeEditable: true,
      wireToController: true,
      selectedWiring:   '',
      selectedSignal:   '',
      assignedChannel:  null,
      assignedCtrlId:   null,
      wireNumber:       null,
      opts: [{
        id:    'generic_' + ioClass,
        lbl:   'Generic ' + ioClass,
        wires: ioClass === 'AO' || ioClass === 'AI' ? 2 : 2,
