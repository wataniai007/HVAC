/* ============================================================
   KEYBOARD SHORTCUTS — COMPLETE SET
   ============================================================ */

function setupGlobalKeyboard() {
  document.addEventListener('keydown', e => {
    const inInput = e.target.tagName === 'INPUT' ||
                    e.target.tagName === 'TEXTAREA' ||
                    e.target.tagName === 'SELECT';

    // Always-on shortcuts
    if ((e.ctrlKey||e.metaKey) && e.key === 's') {
      e.preventDefault();
      if (S.project && typeof saveCS === 'function') { saveCS(); toast('Saved', 'success'); }
      return;
    }
    if ((e.ctrlKey||e.metaKey) && e.key === 'z') {
      e.preventDefault();
      if (typeof canvasUndo === 'function') canvasUndo();
      return;
    }
    if ((e.ctrlKey||e.metaKey) && (e.key === 'y' || (e.shiftKey && e.key === 'z'))) {
      e.preventDefault();
      if (typeof canvasRedo === 'function') canvasRedo();
      return;
    }
    if ((e.ctrlKey||e.metaKey) && e.key === 'c') {
      if (!inInput && typeof canvasCopySelected === 'function') { e.preventDefault(); canvasCopySelected(); }
      return;
    }
    if ((e.ctrlKey||e.metaKey) && e.key === 'v') {
      if (!inInput && typeof canvasPaste === 'function') { e.preventDefault(); canvasPaste(); }
      return;
    }
    if ((e.ctrlKey||e.metaKey) && e.key === 'a') {
      if (!inInput) {
        e.preventDefault();
        if (S.canvas?.objects) {
          S.canvas.selectedIds = S.canvas.objects.map(o => o.id);
          if (typeof renderMainCanvas === 'function') renderMainCanvas();
        }
      }
      return;
    }
    if ((e.ctrlKey||e.metaKey) && e.key === 'p') {
      e.preventDefault();
      exportDrawingPDF();
      return;
    }

    if (inInput) return;

    // Canvas tool shortcuts
    if (e.key === 's' && !e.ctrlKey && !e.metaKey) { if (typeof setCanvasTool==='function') setCanvasTool('select'); else if (typeof setTool==='function') setTool('select'); }
    if (e.key === 'd') { if (typeof setCanvasTool==='function') setCanvasTool('duct');  else if (typeof setTool==='function') setTool('duct'); }
    if (e.key === 'p') { if (typeof setCanvasTool==='function') setCanvasTool('pipe');  else if (typeof setTool==='function') setTool('pipe'); }
    if (e.key === 'w') { if (typeof setCanvasTool==='function') setCanvasTool('wire');  else if (typeof setTool==='function') setTool('wire'); }
    if (e.key === 't') { if (typeof setCanvasTool==='function') setCanvasTool('text');  else if (typeof setTool==='function') setTool('text'); }

    if (e.key === 'r' && S.canvas?.selectedIds?.length) {
      if (typeof rotateSelected === 'function') rotateSelected(90);
    }

    if (e.key === 'Delete' || e.key === 'Backspace') {
      if (S.canvas?.selectedIds?.length && typeof deleteSelectedObjects === 'function') {
        e.preventDefault();
        deleteSelectedObjects();
      }
    }

    if (e.key === 'Escape') {
      if (S.canvas) { S.canvas.selectedIds = []; S.canvas.drawing = null; }
      if (typeof setCanvasTool==='function') setCanvasTool('select');
      else if (typeof setTool==='function') setTool('select');
      if (typeof renderMainCanvas==='function') renderMainCanvas();
      if (typeof renderProps==='function') renderProps(null);
    }

    if (e.key === '+' || e.key === '=') { if (typeof doCanvasZoom==='function') doCanvasZoom(1.15); else if (typeof doZoom==='function') doZoom(1.15); }
    if (e.key === '-')                   { if (typeof doCanvasZoom==='function') doCanvasZoom(0.87); else if (typeof doZoom==='function') doZoom(0.87); }
    if (e.key === '0')                   { if (typeof canvasZoomFit==='function') canvasZoomFit(); }

    if (e.key === 'F1') {
      e.preventDefault();
      showQuickHelp();
    }
  });
}

