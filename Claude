function nextTag(prefix,tags){
  const existing=Object.keys(tags||{}).filter(k=>k.startsWith(prefix+'-')).map(k=>parseInt(k.split('-').pop())).filter(n=>!isNaN(n));
  const next=(existing.length?Math.max(...existing):0)+1;
  const tag=`${prefix}-${next}`;if(tags)tags[tag]=true;return tag;
}
