          <span style="font-size:9px;text-align:center;padding:2px;color:#9ca3af;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb" id="enc-zoom-lbl">${Math.round(ENC.zoom*100/1.5)}%</span>
