    if(stf&&p.status!==stf) return false;
    if(srch&&!(p.name.toLowerCase().includes(srch)||p.num.toLowerCase().includes(srch)||(poles.find(x=>x.id===p.poleId)||{name:''}).name.toLowerCase().includes(srch)||(p.type||'').toLowerCase().includes(srch))) return false;
