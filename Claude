  else{ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);ctx.lineTo(x,y+r);}
  ctx.arcTo(x,y,x+r,y,r);ctx.closePath();
  if(!topOnly){ctx.fill();ctx.stroke();}else ctx.fill();
}
function drawWires(){
  (S.canvasState.wires||[]).forEach(w=>{
    ctx.save();ctx.strokeStyle=w.color||'#6B7280';ctx.lineWidth=1.2;
    ctx.beginPath();ctx.moveTo(w.x1,w.y1);const mx=(w.x1+w.x2)/2;ctx.lineTo(mx,w.y1);ctx.lineTo(mx,w.y2);ctx.lineTo(w.x2,w.y2);ctx.stroke();
    if(w.label){ctx.fillStyle='#374151';ctx.font='7px sans-serif';ctx.textAlign='center';ctx.fillText(w.label,mx,Math.min(w.y1,w.y2)-3);}
    ctx.restore();
  });
}
function drawPreview(){
  const d=S.canvasState.drawing;if(!d) return;
  ctx.save();ctx.strokeStyle='#3B82F6';ctx.lineWidth=1.5;ctx.setLineDash([5,4]);
  if(d.type==='rect')ctx.strokeRect(d.sx,d.sy,d.ex-d.sx,d.ey-d.sy);
  else if(d.type==='wire'){ctx.beginPath();ctx.moveTo(d.sx,d.sy);ctx.lineTo(d.ex||d.sx,d.ey||d.sy);ctx.stroke();}
  ctx.setLineDash([]);ctx.restore();
}
function getComp(obj){
  if(!obj.points||!obj.points.length)return 1;
