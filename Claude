function renderFacilityView() {
  const cont = document.getElementById('ucont');
  if (!cont) return;

  const sites = typeof getSites === 'function' ? getSites() : [];
  const cs    = S.canvas || { objects: [] };
  const ctrls = (cs.objects||[]).filter(o => o.type === 'controller');

  let html = '<div style="flex:1;overflow:auto;padding:20px">';
  html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">';
  html += '<h3 style="font-size:15px;font-weight:700;color:#0f2744">&#127968; Facility / Building / Floor View</h3>';
  html += '</div>';

  if (!sites.length) {
    html += '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:14px;font-size:12px;color:#1d4ed8;margin-bottom:14px">';
    html += '&#8505; No sites defined yet. Go to Admin &gt; Sites to create your site hierarchy (Site &gt; Building &gt; Floor).';
    html += '</div>';
  }

  // Show site hierarchy
  sites.forEach(site => {
    html += '<div class="card" style="margin-bottom:14px">';
    html += '<div class="card-header"><span style="font-size:15px;font-weight:700;color:#0f2744">&#127968; ' + site.name + '</span>';
    html += '<span class="text-sm text-gray">' + (site.city||'') + (site.city&&site.country?', ':'') + (site.country||'') + '</span></div>';
    html += '<div style="padding:0">';

    (site.buildings||[]).forEach(bld => {
      html += '<div style="border-bottom:1px solid #f3f4f6">';
      html += '<div style="padding:10px 16px;background:#f8fafc;font-size:12px;font-weight:700;color:#374151">&#127959; ' + bld.name + '</div>';

      (bld.floors||[]).forEach(fl => {
        const floorCtrls = ctrls.filter(c => {
          const loc = (c.location||'').toLowerCase();
          return loc.includes(fl.name.toLowerCase()) || loc.includes(bld.name.toLowerCase());
        });

        html += '<div style="padding:8px 16px 8px 32px;border-top:1px solid #f3f4f6">';
        html += '<div style="font-size:11px;font-weight:600;color:#6b7280;margin-bottom:5px">&#9632; ' + fl.name + '</div>';

        if (floorCtrls.length) {
          html += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
          floorCtrls.forEach(ctrl => {
            html += '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:6px;padding:5px 10px;font-size:11px">';
            html += '<span style="font-weight:700;color:#1d4ed8">' + ctrl.tag + '</span>';
            html += '<span class="text-sm text-gray" style="margin-left:6px">' + ctrl.model + '</span>';
            html += '</div>';
          });
          html += '</div>';
        } else {
          html += '<div class="text-sm text-gray">No controllers assigned to this floor</div>';
        }
        html += '</div>';
      });
      html += '</div>';
    });
    html += '</div></div>';
  });

  // Unassigned controllers
  const unassigned = ctrls.filter(c => !c.location || c.location.trim() === '');
  if (unassigned.length) {
    html += '<div class="card">';
    html += '<div class="card-header"><span style="font-size:14px;font-weight:700;color:#dc2626">&#9888; Unassigned Controllers</span>';
    html += '<span class="text-sm text-gray">' + unassigned.length + ' controller(s) have no location set</span></div>';
    html += '<div style="padding:12px;display:flex;flex-wrap:wrap;gap:8px">';
    unassigned.forEach(c => {
      html += '<div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:6px;padding:6px 12px;font-size:11px">';
      html += '<span style="font-weight:700;color:#991b1b">' + c.tag + '</span>';
      html += '<span class="text-sm text-gray" style="margin-left:6px">' + c.model + '</span>';
      html += '</div>';
    });
    html += '</div></div>';
  }

  html += '<div style="margin-top:12px;font-size:11px;color:#9ca3af;background:#f9fafb;border-radius:6px;padding:10px">';
  html += '&#128161; Tip: Click a controller on the Schematic canvas, then set its "Location" field in the Properties panel (e.g. Building A / Floor 3 / MER) to assign it here.';
  html += '</div></div>';

  cont.innerHTML = html;
}

/* ============================================================
   IO SUMMARY MODAL — wired to real canvas data
   Shows per-controller, per-system, or per-plant breakdown
   ============================================================ */

function openIOSummaryModal(scope, targetId) {
  const cs     = S.canvas || { objects: [] };
  const ctrls  = (cs.objects||[]).filter(o => o.type === 'controller');
  const devs   = (cs.objects||[]).filter(o => o.type === 'device');

  const scopeSel = document.getElementById('io-summary-scope');
  const targetSel= document.getElementById('io-summary-target');

  if (scopeSel) {
    scopeSel.innerHTML = '<option value="project">Entire Project</option>'
      + '<option value="controller">By Controller</option>'
      + '<option value="plant">By Plant</option>';
    if (scope) scopeSel.value = scope;
  }

  if (targetSel) {
    targetSel.innerHTML = '<option value="">-- Select --</option>';
    ctrls.forEach(c => {
      targetSel.innerHTML += '<option value="ctrl_' + c.id + '">' + c.tag + ' — ' + c.model + '</option>';
    });
    if (targetId) targetSel.value = targetId;
  }

  renderIOSummaryContent();

  if (scopeSel) scopeSel.addEventListener('change', renderIOSummaryContent);
  if (targetSel) targetSel.addEventListener('change', renderIOSummaryContent);

  if (typeof openModal === 'function') openModal('modal-io-summary');
}

function renderIOSummaryContent() {
  const el = document.getElementById('io-summary-content');
  if (!el) return;

  const cs    = S.canvas || { objects: [] };
  const ctrls = (cs.objects||[]).filter(o => o.type === 'controller');
  const devs  = (cs.objects||[]).filter(o => o.type === 'device');
  const scope = document.getElementById('io-summary-scope')?.value || 'project';
  const target= document.getElementById('io-summary-target')?.value || '';

  let html = '';

  if (scope === 'project' || !target) {
    // Whole project summary
    const allPts = devs.flatMap(o => (o.points||[]).filter(p => p.wireToController || p.controllerId));
    const groups = { AI:0, AO:0, DI:0, DO:0 };
    allPts.forEach(p => {
      const wo = (p.opts||[]).find(x => x.id === (p.selectedWire||p.defW)) || p.opts?.[0];
      const io = wo?.ioClass || p.ioClass || 'AI';
      if (groups[io] !== undefined) groups[io]++;
    });
    const assigned = allPts.filter(p => p.assignedChannel).length;
    const unassign = allPts.length - assigned;

    html += '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px">';
    html += `<div class="scard"><div class="si" style="color:#1d4ed8">AI</div><div class="sv">${groups.AI}</div><div class="sl">Analog Inputs</div></div>`;
    html += `<div class="scard"><div class="si" style="color:#065f46">AO</div><div class="sv">${groups.AO}</div><div class="sl">Analog Outputs</div></div>`;
    html += `<div class="scard"><div class="si" style="color:#92400e">DI</div><div class="sv">${groups.DI}</div><div class="sl">Digital Inputs</div></div>`;
    html += `<div class="scard"><div class="si" style="color:#991b1b">DO</div><div class="sv">${groups.DO}</div><div class="sl">Digital Outputs</div></div>`;
    html += '</div>';
    html += '<div style="display:flex;gap:8px;margin-bottom:14px">';
    html += `<span class="badge badge-blue">${allPts.length} total points</span>`;
    html += `<span class="badge badge-green">${assigned} assigned</span>`;
    html += `<span class="badge badge-red">${unassign} unassigned</span>`;
    html += '</div>';

    if (ctrls.length) {
      html += '<div class="tbl-wrap"><table class="tbl"><thead><tr><th>Controller</th><th>Model</th><th>AI</th><th>AO</th><th>DI</th><th>DO</th><th>Total</th><th>Used</th><th>Spare</th></tr></thead><tbody>';
      ctrls.forEach(c => {
        const chs   = c.channels || [];
        const ai    = chs.filter(ch=>ch.cls==='AI').length;
        const ao    = chs.filter(ch=>ch.cls==='AO').length;
        const di    = chs.filter(ch=>ch.cls==='DI').length;
        const doo   = chs.filter(ch=>ch.cls==='DO').length;
        const used  = chs.filter(ch=>ch.assigned).length;
        const spare = chs.length - used;
        html += `<tr><td><b>${c.tag}</b></td><td class="text-gray">${c.model}</td>`
          + `<td style="text-align:center;color:#1d4ed8;font-weight:600">${ai}</td>`
          + `<td style="text-align:center;color:#065f46;font-weight:600">${ao}</td>`
          + `<td style="text-align:center;color:#92400e;font-weight:600">${di}</td>`
          + `<td style="text-align:center;color:#991b1b;font-weight:600">${doo}</td>`
          + `<td style="text-align:center;font-weight:700">${chs.length}</td>`
          + `<td style="text-align:center;color:#065f46">${used}</td>`
          + `<td style="text-align:center;color:${spare<2?'#dc2626':'#6b7280'}">${spare}</td>`
          + '</tr>';
      });
      html += '</tbody></table></div>';
    }

  } else if (scope === 'controller' && target.startsWith('ctrl_')) {
    // Per-controller detail
    const ctrlId = target.replace('ctrl_', '');
    const ctrl   = ctrls.find(c => c.id === ctrlId);
    if (!ctrl) { el.innerHTML = '<div class="text-sm text-gray">Controller not found</div>'; return; }

    const chs = ctrl.channels || [];
    html += `<div style="font-size:14px;font-weight:700;color:#0f2744;margin-bottom:10px">${ctrl.tag} — ${ctrl.model}</div>`;
    html += '<div class="tbl-wrap"><table class="tbl"><thead><tr><th>Channel</th><th>I/O</th><th>Accepted Signals</th><th>Assigned To</th><th>Status</th></tr></thead><tbody>';
    chs.forEach(ch => {
      const bc = { AI:'badge-blue', AO:'badge-green', DI:'badge-yellow', DO:'badge-red', Comm:'badge-purple', Bus:'badge-teal' };
      html += `<tr style="background:${ch.assigned?'#f0fdf4':'#fff'}">`;
      html += `<td><b>${ch.id}</b>${ch.univ?'<span class="badge badge-purple" style="font-size:8px;margin-left:4px">Universal</span>':''}</td>`;
      html += `<td><span class="badge ${bc[ch.cls]||'badge-gray'}" style="font-size:9px">${ch.cls}</span></td>`;
      html += `<td style="font-size:10px;color:#6b7280">${(ch.sigs||[]).slice(0,4).join(', ')}${(ch.sigs||[]).length>4?'…':''}</td>`;
      html += `<td style="font-weight:600;color:${ch.assigned?'#065f46':'#9ca3af'}">${ch.assigned||'—'}</td>`;
      html += `<td>${ch.assigned?'<span style="color:#065f46">&#9989; Assigned</span>':'<span style="color:#9ca3af">&#9744; Free</span>'}</td>`;
      html += '</tr>';
    });
    html += '</tbody></table></div>';

    const used  = chs.filter(c=>c.assigned).length;
    const spare = chs.length - used;
    html += `<div style="display:flex;gap:8px;margin-top:10px">`;
    html += `<span class="badge badge-blue">${chs.length} total channels</span>`;
    html += `<span class="badge badge-green">${used} assigned</span>`;
    html += `<span class="badge badge-${spare<2?'red':'gray'}">${spare} spare</span>`;
    html += `</div>`;
  }

  el.innerHTML = html;
}

/* ============================================================
   WIRE UP NEW NAV ITEMS TO NEW VIEWS
   Extend the existing setUN / nav-item handler to support
   the new views added in this part
   ============================================================ */

const _origSetUN_p11 = typeof setUN === 'function' ? setUN : null;

function setUN(el, s) {
  // Handle new views added in part 11
  if (s === 'enclosure') {
    document.querySelectorAll('#usr-side .nav-item, #user-side .nav-item').forEach(i => i.classList.remove('active'));
    if (el) el.classList.add('active');
    openEnclosureLayoutView();
    return;
  }
  if (s === 'architecture-schedule' || s === 'archschedule') {
    document.querySelectorAll('#usr-side .nav-item, #user-side .nav-item').forEach(i => i.classList.remove('active'));
    if (el) el.classList.add('active');
    renderArchitectureSchedule();
    return;
  }
  if (s === 'facility') {
    document.querySelectorAll('#usr-side .nav-item, #user-side .nav-item').forEach(i => i.classList.remove('active'));
    if (el) el.classList.add('active');
    renderFacilityView();
    return;
  }
  if (_origSetUN_p11) _origSetUN_p11(el, s);
}

/* ============================================================
   ADDITIONAL NAV ITEMS — inject into sidebar dynamically
   so the new views are accessible
   ============================================================ */

function injectP11NavItems() {
  const nav = document.querySelector('#usr-side .sidebar-nav, #user-side .sidebar-nav');
  if (!nav) return;

  // Check if already injected
  if (nav.querySelector('[data-sec="enclosure"]')) return;

  // Add after the existing wiring item
  const wiringItem = nav.querySelector('[onclick*="wiring"],[data-sec="wiring"]');
  if (wiringItem) {
    const encItem = document.createElement('div');
    encItem.className = 'nav-item';
    encItem.setAttribute('data-sec', 'enclosure');
    encItem.innerHTML = '<span class="ni">&#9632;</span>Enclosure';
    encItem.addEventListener('click', () => setUN(encItem, 'enclosure'));
    wiringItem.insertAdjacentElement('afterend', encItem);

    const archItem = document.createElement('div');
    archItem.className = 'nav-item';
    archItem.setAttribute('data-sec', 'archschedule');
    archItem.innerHTML = '<span class="ni">&#128209;</span>Arch. Schedule';
    archItem.addEventListener('click', () => setUN(archItem, 'archschedule'));
    encItem.insertAdjacentElement('afterend', archItem);

    const facItem = document.createElement('div');
    facItem.className = 'nav-item';
    facItem.setAttribute('data-sec', 'facility');
    facItem.innerHTML = '<span class="ni">&#127968;</span>Facility View';
    facItem.addEventListener('click', () => setUN(facItem, 'facility'));
    archItem.insertAdjacentElement('afterend', facItem);
  }
}

