/* ============================================================
   TYPICAL SYSTEM ENGINE
   One schematic represents N identical plants.
   BOM quantities multiplied by typicalCount.
   If one instance diverges, tool splits it out automatically.
   ============================================================ */

function renderTypicalManager() {
  const cont = document.getElementById('ucont');
  if (!cont || !S.project) return;

  const systems = S.project.systems || [];
  const typicals = systems.flatMap(sys =>
    (sys.plants||[]).filter(p => p.isTypical).map(p => ({ ...p, systemName: sys.name, systemId: sys.id }))
  );

  let html = '<div style="flex:1;overflow:auto;padding:20px">';
  html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">';
  html += '<h3 style="font-size:15px;font-weight:700;color:#0f2744">&#128260; Typical Systems Manager</h3>';
  html += '</div>';

  if (!typicals.length) {
    html += '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:14px;font-size:12px;color:#1d4ed8;margin-bottom:14px">';
    html += '&#8505; No typical systems defined. When adding a plant, check "Make this a typical plant" and set the instance count.';
    html += '</div>';
    html += '<div class="empty"><div style="font-size:40px;margin-bottom:12px">&#128260;</div><p>No typical systems yet.<br>Add a plant and mark it as typical to get started.</p></div>';
    html += '</div>'; return;
  }

  typicals.forEach(plt => {
    const overrides = (plt.typicalOverrides || []);
    html += '<div class="card" style="margin-bottom:14px">';
    html += '<div class="card-header">';
    html += '<div><div style="font-size:14px;font-weight:700;color:#0f2744">' + plt.name + '</div>';
    html += '<div class="text-sm text-gray">' + plt.systemName + ' | <span class="badge badge-orange" style="font-size:10px">Typical × ' + plt.typicalCount + '</span></div></div>';
    html += '<div style="display:flex;gap:6px">';
    html += '<button class="btn btn-secondary btn-sm" onclick="expandTypical(\'' + plt.id + '\',\'' + plt.systemId + '\')">&#8599; Expand to ' + plt.typicalCount + ' instances</button>';
    html += '<button class="btn btn-secondary btn-sm" onclick="editTypicalCount(\'' + plt.id + '\',\'' + plt.systemId + '\')" >Edit Count</button>';
    html += '</div></div>';

    // Instance schedule
    html += '<div style="padding:12px">';
    html += '<div style="font-size:11px;font-weight:700;text-transform:uppercase;color:#6b7280;margin-bottom:8px">Instance Schedule</div>';
    html += '<div class="tbl-wrap"><table class="tbl"><thead><tr>';
    html += '<th>#</th><th>Instance Tag</th><th>Location</th><th>Controller</th><th>Variation</th><th></th>';
    html += '</tr></thead><tbody>';

    for (let i = 1; i <= plt.typicalCount; i++) {
      const override = overrides.find(o => o.instanceNum === i) || {};
      const isModified = override.modified;
      html += '<tr style="background:' + (isModified ? '#fff7ed' : '#fff') + '">';
      html += '<td style="color:#9ca3af;font-size:10px">' + i + '</td>';
      html += '<td><input value="' + (override.tag || plt.tag + '-' + String(i).padStart(2,'0')) + '"'
        + ' onchange="updateTypicalOverride(\'' + plt.id + '\',\'' + plt.systemId + '\',' + i + ',\'tag\',this.value)"'
        + ' style="border:none;background:transparent;font-size:11px;font-weight:600;outline:none;width:90px"></td>';
      html += '<td><input value="' + (override.location || '') + '" placeholder="Location..."'
        + ' onchange="updateTypicalOverride(\'' + plt.id + '\',\'' + plt.systemId + '\',' + i + ',\'location\',this.value)"'
        + ' style="border:none;background:transparent;font-size:11px;outline:none;width:120px"></td>';
      html += '<td><input value="' + (override.controller || '') + '" placeholder="Controller..."'
        + ' onchange="updateTypicalOverride(\'' + plt.id + '\',\'' + plt.systemId + '\',' + i + ',\'controller\',this.value)"'
        + ' style="border:none;background:transparent;font-size:11px;outline:none;width:90px"></td>';
      html += '<td>' + (isModified ? '<span class="badge badge-orange" style="font-size:9px">Modified</span>' : '<span class="badge badge-gray" style="font-size:9px">Typical</span>') + '</td>';
      html += '<td><button onclick="makeTypicalOutlier(\'' + plt.id + '\',\'' + plt.systemId + '\',' + i + ')" style="background:none;border:none;cursor:pointer;font-size:10px;color:#6b7280" title="Break from typical">&#8657;</button></td>';
      html += '</tr>';
    }
    html += '</tbody></table></div>';

    // BOM note
    const devs = (plt.canvasObjects||[]).filter(o => o.type === 'device' || o.type === 'controller');
    html += '<div style="margin-top:8px;font-size:11px;color:#6b7280">BOM quantities multiplied × ' + plt.typicalCount + ' for all ' + devs.length + ' devices on this schematic.</div>';
    html += '</div></div>';
  });

  html += '</div>';
  cont.innerHTML = html;
}

function updateTypicalOverride(plantId, systemId, instanceNum, field, val) {
  const sys = (S.project.systems||[]).find(s => s.id === systemId);
  if (!sys) return;
  const plt = (sys.plants||[]).find(p => p.id === plantId);
  if (!plt) return;
  if (!plt.typicalOverrides) plt.typicalOverrides = [];
  let ov = plt.typicalOverrides.find(o => o.instanceNum === instanceNum);
  if (!ov) { ov = { instanceNum }; plt.typicalOverrides.push(ov); }
  ov[field]   = val;
  ov.modified = true;
  if (typeof saveCS === 'function') saveCS();
}

function editTypicalCount(plantId, systemId) {
  const sys = (S.project.systems||[]).find(s => s.id === systemId);
  const plt = sys ? (sys.plants||[]).find(p => p.id === plantId) : null;
  if (!plt) return;
  const newCount = parseInt(prompt('Number of typical instances:', plt.typicalCount) || plt.typicalCount);
  if (isNaN(newCount) || newCount < 1) return;

  if (newCount < plt.typicalCount) {
    const ok = confirm('Reducing count from ' + plt.typicalCount + ' to ' + newCount + '. Any overrides for instances ' + (newCount+1) + '–' + plt.typicalCount + ' will be removed. Continue?');
    if (!ok) return;
    plt.typicalOverrides = (plt.typicalOverrides||[]).filter(o => o.instanceNum <= newCount);
  }
  plt.typicalCount = newCount;
  if (typeof addAudit === 'function') addAudit('canvas', 'Typical count updated: ' + plt.name + ' × ' + newCount);
  if (typeof saveCS === 'function') saveCS();
  renderTypicalManager();
  toast('Typical count updated to ' + newCount, 'success');
}

function makeTypicalOutlier(plantId, systemId, instanceNum) {
  const ok = confirm('This will split instance ' + instanceNum + ' into a standalone plant. The typical count will reduce by 1. Continue?');
  if (!ok) return;

  const sys = (S.project.systems||[]).find(s => s.id === systemId);
  const plt = sys ? (sys.plants||[]).find(p => p.id === plantId) : null;
  if (!plt || plt.typicalCount <= 1) { toast('Cannot split — only 1 instance left', 'error'); return; }

  const ov  = (plt.typicalOverrides||[]).find(o => o.instanceNum === instanceNum) || {};
  const newPlant = {
    id:            uid('plt'),
    name:          ov.tag || plt.name + '-' + String(instanceNum).padStart(2,'0'),
    tag:           ov.tag || plt.tag + '-' + String(instanceNum).padStart(2,'0'),
    type:          plt.type,
    area:          ov.location || plt.area || '',
    controllerId:  ov.controller || plt.controllerId,
    isTypical:     false,
    typicalCount:  1,
    description:   'Split from typical: ' + plt.name,
    canvasObjects: JSON.parse(JSON.stringify(plt.canvasObjects || [])),
    sheets:        []
  };

  sys.plants.push(newPlant);
  plt.typicalCount -= 1;
  plt.typicalOverrides = (plt.typicalOverrides||[]).filter(o => o.instanceNum !== instanceNum);

  if (typeof addAudit === 'function') addAudit('canvas', 'Instance ' + instanceNum + ' split from typical: ' + plt.name);
  if (typeof saveCS === 'function') saveCS();
  if (typeof renderProjectTree === 'function') renderProjectTree();
  renderTypicalManager();
  toast('Instance ' + instanceNum + ' is now a standalone plant: ' + newPlant.name + '. Typical is now × ' + plt.typicalCount, 'warning');
}

function expandTypical(plantId, systemId) {
  const sys = (S.project.systems||[]).find(s => s.id === systemId);
  const plt = sys ? (sys.plants||[]).find(p => p.id === plantId) : null;
  if (!plt) return;

  const ok = confirm('Expand "' + plt.name + '" into ' + plt.typicalCount + ' individual plants? This will replace the typical with ' + plt.typicalCount + ' standalone plants. This cannot be undone.');
  if (!ok) return;

  const newPlants = [];
  for (let i = 1; i <= plt.typicalCount; i++) {
    const ov = (plt.typicalOverrides||[]).find(o => o.instanceNum === i) || {};
    newPlants.push({
      id:           uid('plt'),
      name:         ov.tag || plt.name + '-' + String(i).padStart(2,'0'),
      tag:          ov.tag || plt.tag + '-' + String(i).padStart(2,'0'),
      type:         plt.type,
      area:         ov.location || plt.area || '',
      controllerId: ov.controller || plt.controllerId,
      isTypical:    false,
      typicalCount: 1,
      description:  'Expanded from typical: ' + plt.name,
      canvasObjects:JSON.parse(JSON.stringify(plt.canvasObjects || [])),
      sheets:       []
    });
  }

  sys.plants = sys.plants.filter(p => p.id !== plantId).concat(newPlants);
  if (typeof addAudit === 'function') addAudit('canvas', 'Typical expanded: ' + plt.name + ' → ' + plt.typicalCount + ' plants');
  if (typeof saveCS === 'function') saveCS();
  if (typeof renderProjectTree === 'function') renderProjectTree();
  renderTypicalManager();
  toast('Expanded into ' + plt.typicalCount + ' standalone plants', 'success');
}

/* ============================================================
   COPY / PASTE — PLANT AND SYSTEM
   Deep clone with tag regeneration.
   User can paste into same or different system.
   ============================================================ */

let _copyBuffer = null;

function copyPlant(plantId, systemId) {
  const sys = (S.project.systems||[]).find(s => s.id === systemId);
  const plt = sys ? (sys.plants||[]).find(p => p.id === plantId) : null;
  if (!plt) return;
  _copyBuffer = { type:'plant', data: JSON.parse(JSON.stringify(plt)), sourceSystemId: systemId };
  toast('Plant "' + plt.name + '" copied. Select a system and use Paste Plant.', 'info');
}

function pasteePlant(targetSystemId) {
  if (!_copyBuffer || _copyBuffer.type !== 'plant') { toast('Nothing to paste. Copy a plant first.', 'warning'); return; }
  const sys = (S.project.systems||[]).find(s => s.id === targetSystemId);
  if (!sys) return;
  if (!S.project.tagCounters) S.project.tagCounters = {};

  const src    = _copyBuffer.data;
  const newPlt = JSON.parse(JSON.stringify(src));
  newPlt.id    = uid('plt');

  // Regenerate unique name
  const existingNames = (sys.plants||[]).map(p => p.name);
  let newName = src.name + ' (Copy)';
  let ct = 2;
  while (existingNames.includes(newName)) { newName = src.name + ' (Copy ' + ct + ')'; ct++; }
  newPlt.name = newName;

  // Regenerate all tags
  newPlt.tag = nextTag(S.project, src.tag.replace(/-\d+$/,'') || 'PLT');
  (newPlt.canvasObjects || []).forEach(obj => {
    obj.id  = uid('obj');
    obj.tag = nextTag(S.project, (obj.tag||'OBJ').replace(/-\d+$/,'') || 'OBJ');
    (obj.points||[]).forEach(pt => {
      pt.instanceTag     = nextTag(S.project, (pt.tagPrefix||'PT'));
      pt.assignedChannel = null;
      pt.assignedCtrlId  = null;
      pt.wireNumber      = null;
    });
  });

  if (!sys.plants) sys.plants = [];
  sys.plants.push(newPlt);
  if (typeof addAudit === 'function') addAudit('canvas', 'Plant pasted: ' + newPlt.name);
  if (typeof saveCS === 'function') saveCS();
  if (typeof renderProjectTree === 'function') renderProjectTree();
  toast('Plant pasted as "' + newPlt.name + '"', 'success');
}

function copySystem(systemId) {
  const sys = (S.project.systems||[]).find(s => s.id === systemId);
  if (!sys) return;
  _copyBuffer = { type:'system', data: JSON.parse(JSON.stringify(sys)) };
  toast('System "' + sys.name + '" copied (includes all plants).', 'info');
}

function pasteSystem() {
  if (!_copyBuffer || _copyBuffer.type !== 'system') { toast('Nothing to paste. Copy a system first.', 'warning'); return; }
  if (!S.project.systems) S.project.systems = [];
  if (!S.project.tagCounters) S.project.tagCounters = {};

  const src    = _copyBuffer.data;
  const newSys = JSON.parse(JSON.stringify(src));
  newSys.id    = uid('sys');

  // Regenerate name
  const existingNames = S.project.systems.map(s => s.name);
  let newName = src.name + ' (Copy)';
  let ct = 2;
  while (existingNames.includes(newName)) { newName = src.name + ' (Copy ' + ct + ')'; ct++; }
  newSys.name = newName;
  newSys.tag  = nextTag(S.project, (src.tag||'SYS').replace(/-\d+$/,'') || 'SYS');

  // Regenerate all plant + object tags
  (newSys.plants||[]).forEach(plt => {
    plt.id  = uid('plt');
    plt.tag = nextTag(S.project, (plt.tag||'PLT').replace(/-\d+$/,'') || 'PLT');
    (plt.canvasObjects||[]).forEach(obj => {
      obj.id  = uid('obj');
      obj.tag = nextTag(S.project, (obj.tag||'OBJ').replace(/-\d+$/,'') || 'OBJ');
      (obj.points||[]).forEach(pt => {
        pt.instanceTag     = nextTag(S.project, (pt.tagPrefix||'PT'));
        pt.assignedChannel = null;
        pt.assignedCtrlId  = null;
        pt.wireNumber      = null;
      });
    });
  });

  S.project.systems.push(newSys);
  if (typeof addAudit === 'function') addAudit('canvas', 'System pasted: ' + newSys.name);
  if (typeof saveCS === 'function') saveCS();
  if (typeof renderProjectTree === 'function') renderProjectTree();
  toast('System "' + newSys.name + '" pasted with ' + (newSys.plants||[]).length + ' plant(s)', 'success');
}

/* ============================================================
   GROUPING
   User-defined logical groups for systems/plants.
   Groups are project-level, user-configurable.
   ============================================================ */

function renderGroupManager() {
  const cont = document.getElementById('ucont');
  if (!cont || !S.project) return;

  if (!S.project.groups) S.project.groups = [];
  const groups  = S.project.groups;
  const systems = S.project.systems || [];

  let html = '<div style="flex:1;overflow:auto;padding:20px">';
  html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">';
  html += '<h3 style="font-size:15px;font-weight:700;color:#0f2744">&#128193; System Groups</h3>';
  html += '<button class="btn btn-primary btn-sm" onclick="addGroup()">+ Add Group</button>';
  html += '</div>';

  html += '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:10px;margin-bottom:14px;font-size:11px;color:#1d4ed8">';
  html += '&#8505; Groups are your own organisational labels. A system can belong to one group (e.g. Phase 1, AHUs, Level 3). Groups appear in the Explorer view.';
  html += '</div>';

  if (!groups.length) {
    html += '<div class="empty"><div style="font-size:40px;margin-bottom:12px">&#128193;</div><p>No groups yet. Click + Add Group to organise your systems.</p></div>';
  } else {
    groups.forEach((grp, gi) => {
      const grpSystems = systems.filter(s => s.group === grp.name);
      html += '<div class="card" style="margin-bottom:12px">';
      html += '<div class="card-header">';
      html += '<div style="display:flex;align-items:center;gap:8px">';
      html += '<div style="width:12px;height:12px;border-radius:50%;background:' + (grp.color||'#2563eb') + '"></div>';
      html += '<input value="' + grp.name + '" onchange="updateGroupName(' + gi + ',this.value)" style="font-size:14px;font-weight:700;color:#0f2744;border:none;background:transparent;outline:none">';
      html += '<span class="badge badge-blue" style="font-size:9px">' + grpSystems.length + ' systems</span>';
      html += '</div>';
      html += '<div style="display:flex;gap:4px">';
      html += '<input type="color" value="' + (grp.color||'#2563eb') + '" onchange="updateGroupColor(' + gi + ',this.value)" style="width:28px;height:28px;border:1px solid #e5e7eb;border-radius:4px;cursor:pointer;padding:2px">';
      html += '<button onclick="deleteGroup(' + gi + ')" class="btn-icon" style="color:var(--red)">&#128465;</button>';
      html += '</div></div>';
      html += '<div style="padding:12px">';
      if (!grpSystems.length) {
        html += '<div class="text-sm text-gray">No systems in this group. Edit a system and set its group to "' + grp.name + '".</div>';
      } else {
        html += '<div style="display:flex;flex-wrap:wrap;gap:6px">';
        grpSystems.forEach(sys => {
          html += '<div style="background:' + (grp.color||'#2563eb') + '22;border:1px solid ' + (grp.color||'#2563eb') + '44;border-radius:6px;padding:5px 10px;font-size:11px">';
          html += '<span style="font-weight:600">' + sys.name + '</span>';
          html += '<span class="text-sm text-gray" style="margin-left:4px">(' + (sys.plants||[]).length + ' plants)</span>';
          html += '</div>';
        });
        html += '</div>';
      }

      // Unassigned systems dropdown
      const unassigned = systems.filter(s => !s.group || s.group === '');
      if (unassigned.length) {
        html += '<div style="margin-top:8px;display:flex;gap:6px;align-items:center">';
        html += '<select id="add-to-grp-' + gi + '" style="font-size:11px;border:1px solid #e5e7eb;border-radius:4px;padding:3px 7px">';
        html += '<option value="">Add system to this group...</option>';
        unassigned.forEach(s => { html += '<option value="' + s.id + '">' + s.name + '</option>'; });
        html += '</select>';
        html += '<button class="btn btn-secondary btn-sm" onclick="addSystemToGroup(\'' + grp.name + '\',' + gi + ')">Add</button>';
        html += '</div>';
      }

      html += '</div></div>';
    });
  }

  // Ungrouped systems
  const ungrouped = systems.filter(s => !s.group || s.group === '');
  if (ungrouped.length) {
    html += '<div class="card"><div class="card-header"><span style="font-weight:700;color:#6b7280">Ungrouped Systems (' + ungrouped.length + ')</span></div>';
    html += '<div style="padding:12px;display:flex;flex-wrap:wrap;gap:6px">';
    ungrouped.forEach(sys => {
      html += '<span style="background:#f3f4f6;border:1px solid #e5e7eb;border-radius:6px;padding:4px 10px;font-size:11px">' + sys.name + '</span>';
    });
    html += '</div></div>';
  }

  html += '</div>';
  cont.innerHTML = html;
}

function addGroup() {
  const name = prompt('Group name (e.g. Phase 1, AHUs, FCUs):');
  if (!name) return;
  if (!S.project.groups) S.project.groups = [];
  if (S.project.groups.find(g => g.name === name)) { toast('Group already exists', 'warning'); return; }
  const colors = ['#2563eb','#059669','#dc2626','#7c3aed','#d97706','#0891b2'];
  S.project.groups.push({ name, color: colors[S.project.groups.length % colors.length] });
  if (typeof saveCS === 'function') saveCS();
  renderGroupManager();
}

function updateGroupName(gi, name) {
  if (!S.project.groups?.[gi]) return;
  const old = S.project.groups[gi].name;
  S.project.groups[gi].name = name;
  // Update all systems using old name
  (S.project.systems||[]).forEach(s => { if (s.group === old) s.group = name; });
  if (typeof saveCS === 'function') saveCS();
}

function updateGroupColor(gi, color) {
  if (!S.project.groups?.[gi]) return;
  S.project.groups[gi].color = color;
  if (typeof saveCS === 'function') saveCS();
  renderGroupManager();
}

function deleteGroup(gi) {
  if (!S.project.groups?.[gi]) return;
  const grp = S.project.groups[gi];
  if (!confirm('Delete group "' + grp.name + '"? Systems in this group will become ungrouped.')) return;
  (S.project.systems||[]).forEach(s => { if (s.group === grp.name) s.group = ''; });
  S.project.groups.splice(gi, 1);
  if (typeof saveCS === 'function') saveCS();
  renderGroupManager();
}

function addSystemToGroup(groupName, gi) {
  const sel = document.getElementById('add-to-grp-' + gi);
  if (!sel?.value) return;
  const sys = (S.project.systems||[]).find(s => s.id === sel.value);
  if (!sys) return;
  sys.group = groupName;
  if (typeof saveCS === 'function') saveCS();
  renderGroupManager();
  toast(sys.name + ' added to group "' + groupName + '"', 'success');
}

/* ============================================================
   PROJECT-WIDE SEARCH
   Searches tags, point names, plant names, controller tags,
   part numbers, notes — returns results with navigation links.
   ============================================================ */

function renderProjectSearch() {
  const cont = document.getElementById('ucont');
  if (!cont) return;

  let html = '<div style="flex:1;display:flex;flex-direction:column;overflow:hidden">';
  html += '<div style="background:#fff;border-bottom:1px solid #e5e7eb;padding:12px 16px;display:flex;gap:10px;align-items:center;flex-shrink:0">';
  html += '<span style="font-size:14px;font-weight:700;color:#0f2744">&#128269; Project Search</span>';
  html += '<input class="form-input" id="proj-search-q" placeholder="Search tags, point names, devices, controllers, notes..." style="flex:1;font-size:13px">';
  html += '<button class="btn btn-primary" onclick="runProjectSearch()">Search</button>';
  html += '</div>';
  html += '<div style="flex:1;overflow-y:auto;padding:16px" id="proj-search-results">';
  html += '<div class="text-sm text-gray" style="text-align:center;padding:32px">Type a search term above and click Search, or press Enter.</div>';
  html += '</div></div>';

  cont.innerHTML = html;

  const input = document.getElementById('proj-search-q');
  if (input) input.addEventListener('keydown', e => { if (e.key === 'Enter') runProjectSearch(); });
}

function runProjectSearch() {
  const q = (document.getElementById('proj-search-q')?.value || '').toLowerCase().trim();
  if (!q) return;

  const results = [];
  const cs = S.canvas || { objects: [] };

  // Search canvas objects
  (cs.objects||[]).forEach(obj => {
    const fields = [obj.tag, obj.model, obj.manufacturer, obj.description, obj.notes, obj.location].filter(Boolean).join(' ').toLowerCase();
    if (fields.includes(q)) {
      results.push({ type: 'object', label: obj.tag + ' — ' + (obj.model||obj.type), sub: obj.description||'', objId: obj.id, icon: obj.type==='controller'?'🖥':'⬤' });
    }
    // Search points
    (obj.points||[]).forEach(pt => {
      const ptFields = [pt.instanceTag, pt.pointName, pt.role, pt.signalType].filter(Boolean).join(' ').toLowerCase();
      if (ptFields.includes(q)) {
        results.push({ type: 'point', label: pt.instanceTag + ' — ' + pt.role, sub: 'on ' + obj.tag + ' | ' + (pt.pointName||''), objId: obj.id, icon: '📋' });
      }
    });
  });

  // Search systems and plants
  (S.project?.systems||[]).forEach(sys => {
    if ((sys.name||'').toLowerCase().includes(q) || (sys.tag||'').toLowerCase().includes(q)) {
      results.push({ type: 'system', label: sys.name, sub: sys.tag + ' | ' + (sys.group||'Ungrouped'), icon: '📁' });
    }
    (sys.plants||[]).forEach(plt => {
      if ((plt.name||'').toLowerCase().includes(q) || (plt.tag||'').toLowerCase().includes(q) || (plt.area||'').toLowerCase().includes(q)) {
        results.push({ type: 'plant', label: plt.name, sub: plt.tag + ' | System: ' + sys.name, icon: '🔷' });
      }
    });
  });

  // Search schedules
  Object.keys(S.project?.schedules||{}).forEach(schType => {
    (S.project.schedules[schType]||[]).forEach((row, ri) => {
      const rowStr = Object.values(row).join(' ').toLowerCase();
      if (rowStr.includes(q)) {
        results.push({ type: 'schedule', label: schType.toUpperCase() + ' Row ' + (ri+1) + ': ' + (row.tag||''), sub: Object.entries(row).filter(([k,v])=>v&&String(v).toLowerCase().includes(q)).map(([k,v])=>k+': '+v).join(', '), icon: '📋', schedType: schType });
      }
    });
  });

  // Search sequences
  (S.project?.sequences||[]).forEach((seq, si) => {
    if ((seq.title||'').toLowerCase().includes(q) || (seq.context||'').toLowerCase().includes(q)) {
      results.push({ type: 'sequence', label: seq.title, sub: seq.context || '', seqIdx: si, icon: '📝' });
    }
    (seq.sections||[]).forEach(sec => {
      if ((sec.content||'').toLowerCase().includes(q)) {
        results.push({ type: 'sequence-section', label: seq.title + ' → ' + sec.title, sub: sec.content.substring(0,100) + '…', seqIdx: si, icon: '📝' });
      }
    });
  });

  const el = document.getElementById('proj-search-results');
  if (!el) return;

  if (!results.length) {
    el.innerHTML = '<div style="text-align:center;padding:32px;color:#9ca3af"><div style="font-size:32px;margin-bottom:10px">🔍</div><p>No results found for "' + q + '"</p></div>';
    return;
  }

  const grouped = {};
  results.forEach(r => {
    if (!grouped[r.type]) grouped[r.type] = [];
    grouped[r.type].push(r);
  });

  const typeLabels = { object:'Canvas Objects', point:'Points', system:'Systems', plant:'Plants', schedule:'Schedules', sequence:'Sequences', 'sequence-section':'Sequence Content' };
  let html = '<div style="margin-bottom:10px;font-size:12px;color:#6b7280">' + results.length + ' result(s) for "<b>' + q + '</b>"</div>';

  Object.keys(grouped).forEach(type => {
    html += '<div style="margin-bottom:14px">';
    html += '<div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#6b7280;margin-bottom:6px">' + (typeLabels[type]||type) + ' (' + grouped[type].length + ')</div>';
    grouped[type].forEach(r => {
      let action = '';
      if (r.objId) action = 'onclick="selectObj(\'' + r.objId + '\');setUN(null,\'schematic\')"';
      else if (r.schedType) action = 'onclick="setUN(null,\'' + r.schedType + '\')"';
      else if (r.seqIdx !== undefined) action = 'onclick="S._selectedSeq=' + r.seqIdx + ';setUN(null,\'sequence\')"';

      const qLow = q.toLowerCase();
      const labelHl = (r.label||'').replace(new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')', 'gi'), '<mark style="background:#fef9c3;border-radius:2px">$1</mark>');

      html += '<div class="card card-hover" style="margin-bottom:6px;padding:10px 14px;display:flex;align-items:center;gap:10px" ' + action + '>';
      html += '<span style="font-size:16px;flex-shrink:0">' + r.icon + '</span>';
      html += '<div style="flex:1;min-width:0"><div style="font-size:12px;font-weight:600;color:#0f2744">' + labelHl + '</div>';
      if (r.sub) html += '<div class="text-sm text-gray" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + r.sub + '</div>';
      html += '</div>';
      html += '<span class="badge badge-gray" style="font-size:9px;flex-shrink:0">' + (typeLabels[r.type]||r.type) + '</span>';
      html += '</div>';
    });
    html += '</div>';
  });

  el.innerHTML = html;
}

/* ============================================================
   FAVOURITES / PINNED PART TYPES
   User can pin part types to top of library.
   Stored per-user in localStorage.
   Admin can view all user favourites and promote to master.
   ============================================================ */

function loadUserFavourites() {
  try {
    const key = 'hvac_favourites_' + (S.user?.id||'guest');
    return JSON.parse(localStorage.getItem(key)||'[]');
  } catch(e) { return []; }
}

function saveUserFavourites(favs) {
  try {
    const key = 'hvac_favourites_' + (S.user?.id||'guest');
    localStorage.setItem(key, JSON.stringify(favs));
  } catch(e) {}
}

function toggleFavourite(ptId) {
  const favs = loadUserFavourites();
  const idx  = favs.indexOf(ptId);
  if (idx >= 0) {
    favs.splice(idx, 1);
    toast('Removed from favourites', 'info');
  } else {
    favs.push(ptId);
    toast('Added to favourites', 'success');
  }
  saveUserFavourites(favs);
  if (typeof buildLibTree === 'function') buildLibTree('');
  S.pinned = favs;
}

function renderFavouritesAdmin(main, acts) {
  const allUsers = typeof getUsers === 'function' ? getUsers() : [];
  let html = '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:12px;margin-bottom:14px;font-size:12px;color:#1d4ed8">';
  html += '&#11088; These are part types that users have marked as favourites. Admin can promote frequently-favourited shapes to the master library.';
  html += '</div>';

  let allFavs = [];
  allUsers.forEach(u => {
    try {
      const favs = JSON.parse(localStorage.getItem('hvac_favourites_' + u.id)||'[]');
      favs.forEach(ptId => {
        let entry = allFavs.find(f => f.ptId === ptId);
        if (!entry) { entry = { ptId, users: [] }; allFavs.push(entry); }
        entry.users.push(u.fn + ' ' + u.ln);
      });
    } catch(e) {}
  });

  if (!allFavs.length) {
    html += '<div class="empty"><div style="font-size:40px;margin-bottom:10px">&#11088;</div><p>No favourites recorded yet.</p></div>';
  } else {
    const pts = typeof getPartTypes === 'function' ? getPartTypes() : [];
    html += '<div class="tbl-wrap"><table class="tbl"><thead><tr><th>Part Type</th><th>Symbol</th><th>Favourited By</th><th>Actions</th></tr></thead><tbody>';
    allFavs.sort((a,b) => b.users.length - a.users.length).forEach(f => {
      const pt = pts.find(p => p.id === f.ptId);
      html += '<tr><td><b>' + (pt?.name||f.ptId) + '</b></td>';
      html += '<td><span style="font-size:16px;background:#f3f4f6;padding:3px 8px;border-radius:4px">' + (pt?.symbol||'?') + '</span></td>';
      html += '<td class="text-sm text-gray">' + f.users.join(', ') + '</td>';
      html += '<td><span class="badge badge-blue" style="font-size:9px">' + f.users.length + ' user(s)</span></td>';
      html += '</tr>';
    });
    html += '</tbody></table></div>';
  }

  main.innerHTML = html;
}

/* ============================================================
   VALVE SIZING — WIRED TO CANVAS TAGS
   Valve sizing schedule now auto-imports valve tags
   from canvas devices and syncs tag changes back.
   ============================================================ */

function syncValveScheduleFromCanvas() {
  if (!S.project) return;
  if (!S.project.schedules) S.project.schedules = {};
  if (!S.project.schedules.valves) S.project.schedules.valves = [];

  const cs       = S.canvas || { objects: [] };
  const canvasValves = (cs.objects||[]).filter(o =>
    o.type === 'device' &&
    (o.description||'').toLowerCase().includes('valve') ||
    (o.model||'').toLowerCase().includes('valve') ||
    (o.model||'').toLowerCase().includes('vg') ||
    (o.symbol||'').toUpperCase() === 'CV'
  );

  let added = 0;
  canvasValves.forEach(obj => {
    const existing = S.project.schedules.valves.find(r => r._canvasId === obj.id);
    if (!existing) {
      S.project.schedules.valves.push({
        tag:       obj.tag,
        service:   'CHWS',
        systemTag: '',
        sizein:    '',
        cv:        '',
        flowGpm:   '',
        closeoffPsi: '',
        actuator:  '',
        failPos:   'Fail Closed',
        signal:    '0-10VDC',
        notes:     '',
        _canvasId: obj.id
      });
      added++;
    }
  });

  if (added > 0) {
    if (typeof saveCS === 'function') saveCS();
    toast(added + ' valve(s) imported from canvas to Valve Schedule', 'success');
  }
  return added;
}

function syncDamperScheduleFromCanvas() {
  if (!S.project) return;
  if (!S.project.schedules) S.project.schedules = {};
  if (!S.project.schedules.dampers) S.project.schedules.dampers = [];

  const cs = S.canvas || { objects: [] };
  const canvasDampers = (cs.objects||[]).filter(o =>
    o.type === 'device' &&
    ((o.description||'').toLowerCase().includes('damper') ||
     (o.symbol||'').toUpperCase() === 'DA')
  );

  let added = 0;
  canvasDampers.forEach(obj => {
    const existing = S.project.schedules.dampers.find(r => r._canvasId === obj.id);
    if (!existing) {
      S.project.schedules.dampers.push({
        tag:       obj.tag,
        service:   'OA',
        ductSize:  '',
        cfm:       '',
        actuator:  obj.model||'',
        failPos:   'Fail Closed',
        signal:    '0-10VDC',
        location:  obj.notes||'',
        notes:     '',
        _canvasId: obj.id
      });
      added++;
    }
  });

  if (added > 0) {
    if (typeof saveCS === 'function') saveCS();
    toast(added + ' damper(s) imported from canvas to Damper Schedule', 'success');
  }
  return added;
}

/* When schedule views open, auto-sync from canvas */
const _origRenderSchedule = typeof renderSchedule === 'function' ? renderSchedule : null;
function renderSchedule(type) {
  if (type === 'valves')  syncValveScheduleFromCanvas();
  if (type === 'dampers') syncDamperScheduleFromCanvas();
  if (_origRenderSchedule) _origRenderSchedule(type);
