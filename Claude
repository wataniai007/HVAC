function drawGrid(){
  const cs=S.canvasState;const step=20;
  const w=canvas.width/cs.zoom,h=canvas.height/cs.zoom;
  const ox=-cs.pan.x/cs.zoom,oy=-cs.pan.y/cs.zoom;
  ctx.strokeStyle='#E8ECF0';ctx.lineWidth=.5;
  for(let x=Math.floor(ox/step)*step;x<ox+w;x+=step){ctx.beginPath();ctx.moveTo(x,oy);ctx.lineTo(x,oy+h);ctx.stroke();}
  for(let y=Math.floor(oy/step)*step;y<oy+h;y+=step){ctx.beginPath();ctx.moveTo(ox,y);ctx.lineTo(ox+w,y);ctx.stroke();}
}
function drawObj(obj){
  const sel=S.canvasState.selected===obj.id;
