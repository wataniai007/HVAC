   PART 10 — POINT-TO-POINT WIRING ENGINE
   Terminal rendering, elastic wire connections,
   waypoint routing, wire labels, terminal drag
   ============================================================ */

/* ============================================================
   TERMINAL SYSTEM
   Each device object gets terminals auto-generated from its
   points when placed. Terminals have a position relative to
   the object and act as wire anchors.
   ============================================================ */

function generateTerminals(obj) {
  if (!obj.points || !obj.points.length) return [];
  const terminals = [];
  const spacing = obj.h / (obj.points.length + 1);

  obj.points.forEach((pt, i) => {
    const wopt = (pt.opts||[]).find(o => o.id === (pt.selectedWire || pt.defW)) || pt.opts?.[0];
    const terms = wopt ? (wopt.terms || []) : [];

    terms.forEach((termLabel, j) => {
      terminals.push({
        id:       pt.instanceTag + '_T' + j,
        pointIdx: i,
        termIdx:  j,
        label:    termLabel,
        relX:     obj.w + 8,
        relY:     spacing * (i + 1) + (j - (terms.length-1)/2) * 10,
        side:     'right',
        wireColor: getWireColor(wopt, S.project)
      });
    });

    // Power terminals on left side if not loop powered
    if (wopt && !wopt.lp && wopt.wires > 1) {
      terminals.push({
        id:       pt.instanceTag + '_PWR',
        pointIdx: i,
        termIdx:  99,
        label:    '+24V',
        relX:     -8,
        relY:     spacing * (i + 1),
        side:     'left',
        wireColor: '#10b981'
      });
    }
  });

  return terminals;
}

function getWireColor(wopt, project) {
  if (!wopt) return '#6b7280';
  const io = wopt.ioClass || 'AI';
  const strategy = project?.supplierStrategy || 'default';
  // Default wire colours (can be made pole-configurable later)
  const colours = { AI:'#ef4444', AO:'#3b82f6', DI:'#ffffff', DO:'#f97316', GND:'#111827', PWR:'#10b981' };
  return colours[io] || '#6b7280';
}

/* ============================================================
   POINT-TO-POINT WIRING VIEW
   Shows the schematic in wire-level detail:
   - Each part shows its terminal screws
   - Wires connect terminals to power supply / controller
   - Generic terminals (+24V, COM, S, C) shown when
     PSU/controller not yet assigned
   ============================================================ */

