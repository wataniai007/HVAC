/* ============================================================
   POWER SUPPLY ASSIGNMENT + REAL-TIME VA CALCULATION
   Each device that requires 24VAC is assigned to a PSU.
   Tool calculates real-time current draw and warns on overload.
   ============================================================ */

const PSU_VA_ESTIMATES = {
  'Sensor':     8,
  'Actuator':  12,
  'Relay':      5,
  'Controller':30,
  'IO Module':  8,
  'default':    6
};

function getPSUDevices() {
  const cs = S.canvas || { objects: [] };
  return (cs.objects||[]).filter(o => o.type === 'device' || o.type === 'controller');
}

function getDeviceVA(obj) {
  const allParts = typeof getParts === 'function' ? getParts() : [];
  const allCtrls = typeof getControllers === 'function' ? getControllers() : [];
  const part = [...allParts,...allCtrls].find(p => p.id === (obj.devId||obj.ctrlId));
  if (part?.powerVA) return part.powerVA;
  const cat = part?.category || obj.category || 'default';
  return PSU_VA_ESTIMATES[cat] || PSU_VA_ESTIMATES.default;
}

function renderPSUAssignmentView() {
  const cont = document.getElementById('ucont');
  if (!cont || !S.project) return;

  if (!S.project.psus) S.project.psus = [];
  const psus = S.project.psus;
  const devs = getPSUDevices();

  let html = '<div style="flex:1;overflow:auto;padding:20px">';
  html += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">';
  html += '<h3 style="font-size:15px;font-weight:700;color:#0f2744">&#9889; Power Supply Assignment</h3>';
  html += '<button class="btn btn-primary btn-sm" onclick="addPSU()">+ Add Power Supply</button>';
  html += '</div>';

  html += '<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;padding:10px;margin-bottom:14px;font-size:11px;color:#1d4ed8">';
  html += '&#8505; Assign devices to power supplies. The tool calculates estimated VA draw in real time and warns when a PSU is near or over capacity.';
  html += '</div>';

  if (!psus.length) {
    html += '<div class="empty"><div style="font-size:40px;margin-bottom:10px">&#9889;</div>';
    html += '<p>No power supplies defined. Click + Add Power Supply to create one.</p></div>';
    html += '</div>'; return;
  }

  psus.forEach((psu, pi) => {
    const assignedDevs = devs.filter(d => d.psuId === psu.id);
    const totalVA = assignedDevs.reduce((sum, d) => sum + getDeviceVA(d), 0);
    const capacity = psu.capacityVA || 80;
    const pct = Math.min(100, Math.round(totalVA / capacity * 100));
    const barColor = pct > 90 ? '#ef4444' : pct > 75 ? '#f59e0b' : '#10b981';
    const overloaded = totalVA > capacity;

    html += '<div class="card" style="margin-bottom:14px">';
    html += '<div class="card-header">';
    html += '<div>';
    html += '<div style="font-size:14px;font-weight:700;color:#0f2744">' + psu.tag + ' — ' + (psu.model||'24VAC Power Supply') + '</div>';
    html += '<div class="text-sm text-gray">' + psu.outputVoltage + ' | ' + capacity + ' VA capacity</div>';
    html += '</div>';
    html += '<div style="display:flex;gap:6px">';
    html += '<button class="btn btn-secondary btn-sm" onclick="editPSU(' + pi + ')">Edit</button>';
    html += '<button class="btn btn-danger btn-sm" onclick="deletePSU(' + pi + ')">Delete</button>';
    html += '</div></div>';
    html += '<div style="padding:14px">';

    // VA bar
    html += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">';
    html += '<div style="flex:1;height:10px;background:#e5e7eb;border-radius:5px;overflow:hidden">';
    html += '<div style="height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:5px;transition:width .3s"></div>';
    html += '</div>';
    html += '<span style="font-size:11px;font-weight:700;color:' + (overloaded?'#dc2626':'#374151') + '">' + totalVA + ' / ' + capacity + ' VA</span>';
    if (overloaded) html += '<span class="badge badge-red" style="font-size:9px">&#9888; OVERLOADED</span>';
    html += '</div>';

    // Assigned devices table
    if (assignedDevs.length) {
      html += '<div class="tbl-wrap" style="margin-bottom:10px"><table class="tbl"><thead><tr>';
      html += '<th>Tag</th><th>Model</th><th>Category</th><th>Est. VA</th><th></th>';
      html += '</tr></thead><tbody>';
      assignedDevs.forEach(dev => {
        const va = getDeviceVA(dev);
        html += '<tr><td><b>' + dev.tag + '</b></td><td class="text-gray">' + (dev.model||'') + '</td>';
        html += '<td><span class="badge badge-gray" style="font-size:9px">' + (dev.category||dev.type||'Device') + '</span></td>';
        html += '<td><span style="font-weight:600;color:#374151">' + va + ' VA</span></td>';
        html += '<td><button onclick="unassignFromPSU(\'' + dev.id + '\')" class="btn-icon" style="font-size:10px;padding:2px 5px;color:var(--red)">&#10005;</button></td>';
        html += '</tr>';
      });
      html += '</tbody></table></div>';
    } else {
      html += '<div class="text-sm text-gray" style="margin-bottom:10px">No devices assigned yet.</div>';
    }

    // Assign device dropdown
    const unassigned = devs.filter(d => !d.psuId);
    if (unassigned.length) {
      html += '<div style="display:flex;gap:6px;align-items:center">';
      html += '<select id="psu-add-dev-' + pi + '" style="font-size:11px;border:1px solid #e5e7eb;border-radius:4px;padding:3px 8px;flex:1">';
      html += '<option value="">Assign device to this PSU...</option>';
      unassigned.forEach(d => {
        const va = getDeviceVA(d);
        html += '<option value="' + d.id + '">' + d.tag + ' — ' + (d.model||'') + ' (~' + va + ' VA)</option>';
      });
      html += '</select>';
      html += '<button class="btn btn-primary btn-sm" onclick="assignToPSU(\'' + psu.id + '\',' + pi + ')">Assign</button>';
      html += '</div>';
    }

    html += '</div></div>';
  });

  // Unassigned devices summary
  const unassignedAll = devs.filter(d => !d.psuId);
  if (unassignedAll.length) {
    html += '<div style="background:#fff7ed;border:1px solid #fed7aa;border-radius:8px;padding:12px;font-size:11px;color:#c2410c">';
    html += '&#9888; ' + unassignedAll.length + ' device(s) not assigned to any power supply: ';
    html += unassignedAll.map(d => '<b>' + d.tag + '</b>').join(', ');
    html += '</div>';
  }

  html += '</div>';
  cont.innerHTML = html;
}

function addPSU() {
  if (!S.project) return;
  if (!S.project.psus) S.project.psus = [];
  if (!S.project.tagCounters) S.project.tagCounters = {};
  const tag = nextTag(S.project, 'PS');
  S.project.psus.push({
    id:              uid('psu'),
    tag,
    model:           '24VAC Power Supply',
    outputVoltage:   '24VAC',
    capacityVA:      80,
    inputVoltage:    '120VAC',
    location:        '',
    enclosureId:     null
  });
  if (typeof addAudit === 'function') addAudit('canvas', 'Power supply added: ' + tag);
  if (typeof saveCS === 'function') saveCS();
  renderPSUAssignmentView();
}

function editPSU(pi) {
  if (!S.project?.psus?.[pi]) return;
  const psu = S.project.psus[pi];
  const cap = prompt('PSU capacity (VA):', psu.capacityVA);
  if (!cap) return;
  psu.capacityVA = parseInt(cap) || 80;
  const model = prompt('Model:', psu.model);
  if (model) psu.model = model;
  if (typeof saveCS === 'function') saveCS();
  renderPSUAssignmentView();
}

function deletePSU(pi) {
  if (!S.project?.psus?.[pi]) return;
  if (!confirm('Delete this power supply? Assigned devices will become unassigned.')) return;
  const psuId = S.project.psus[pi].id;
  getPSUDevices().forEach(d => { if (d.psuId === psuId) delete d.psuId; });
  S.project.psus.splice(pi, 1);
  if (typeof saveCS === 'function') saveCS();
  renderPSUAssignmentView();
}

function assignToPSU(psuId, pi) {
  const sel = document.getElementById('psu-add-dev-' + pi);
  if (!sel?.value) return;
  const dev = getPSUDevices().find(d => d.id === sel.value);
  if (!dev) return;
  dev.psuId = psuId;
  if (typeof addAudit === 'function') addAudit('canvas', dev.tag + ' assigned to PSU');
  if (typeof saveCS === 'function') saveCS();
  renderPSUAssignmentView();
  toast(dev.tag + ' assigned to power supply', 'success');
}

function unassignFromPSU(devId) {
  const dev = getPSUDevices().find(d => d.id === devId);
  if (!dev) return;
  delete dev.psuId;
  if (typeof saveCS === 'function') saveCS();
  renderPSUAssignmentView();
}

/* ============================================================
   IO OVERFLOW WARNINGS
   Checks every controller for channel overuse and
   signal-type mismatches. Fires inline warnings.
   ============================================================ */

function runIOValidation() {
  const cs = S.canvas || { objects: [] };
  const warnings = [];
  const ctrls  = (cs.objects||[]).filter(o => o.type === 'controller');
  const devs   = (cs.objects||[]).filter(o => o.type === 'device');

  ctrls.forEach(ctrl => {
    const chs = ctrl.channels || [];
    const ai  = chs.filter(c => c.cls === 'AI').length;
    const ao  = chs.filter(c => c.cls === 'AO').length;
    const di  = chs.filter(c => c.cls === 'DI').length;
    const doo = chs.filter(c => c.cls === 'DO').length;
    const used = chs.filter(c => c.assigned).length;

    // Overflow check
    if (used >= chs.length && chs.length > 0) {
      warnings.push({ severity:'error', objId: ctrl.id, tag: ctrl.tag,
        msg: ctrl.tag + ' is at full capacity (' + used + '/' + chs.length + ' channels used). Add an expansion module.' });
    } else if (used >= chs.length * 0.9 && chs.length > 0) {
      warnings.push({ severity:'warning', objId: ctrl.id, tag: ctrl.tag,
        msg: ctrl.tag + ' is nearly full (' + used + '/' + chs.length + ' channels used). Consider adding expansion.' });
    }

    // Signal mismatch check
    devs.forEach(dev => {
      (dev.points||[]).forEach(pt => {
        if (pt.assignedCtrlId !== ctrl.id || !pt.assignedChannel) return;
        const ch = chs.find(c => c.id === pt.assignedChannel);
        if (!ch) return;
        const wo = (pt.opts||[]).find(o => o.id === (pt.selectedWire||pt.defW)) || pt.opts?.[0];
        if (!wo) return;
        if (!(ch.sigs||[]).includes(wo.sig) && ch.cls !== wo.ioClass) {
          warnings.push({ severity:'error', objId: dev.id, tag: dev.tag,
            msg: pt.instanceTag + ' signal "' + wo.sig + '" is incompatible with ' + ctrl.tag + ' channel ' + pt.assignedChannel + ' (' + (ch.sigs||[]).join(', ') + ')' });
        }
      });
    });
  });

  // Unassigned wire-to-controller points
  devs.forEach(dev => {
    const unassigned = (dev.points||[]).filter(pt => pt.wireToController && !pt.assignedChannel);
    if (unassigned.length) {
      warnings.push({ severity:'warning', objId: dev.id, tag: dev.tag,
        msg: dev.tag + ' has ' + unassigned.length + ' unassigned point(s): ' + unassigned.map(p=>p.instanceTag||p.tagPrefix||'').join(', ') });
    }
  });

  // PSU overloads
  (S.project?.psus||[]).forEach(psu => {
    const assigned = getPSUDevices().filter(d => d.psuId === psu.id);
    const totalVA  = assigned.reduce((s,d) => s + getDeviceVA(d), 0);
    if (totalVA > (psu.capacityVA||80)) {
      warnings.push({ severity:'error', tag: psu.tag,
        msg: psu.tag + ' is overloaded: ' + totalVA + 'VA used / ' + (psu.capacityVA||80) + 'VA capacity' });
    }
  });

  return warnings;
}

