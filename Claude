  return null;
}
function toggleLib(lid){const ls=DB.get('lib-structure')||[];const l=ls.find(x=>x.id===lid);if(l)l.exp=!l.exp;DB.set('lib-structure',ls);buildLibTree(document.getElementById('lib-search').value||'');}
function toggleCat(lid,cid){const ls=DB.get('lib-structure')||[];const l=ls.find(x=>x.id===lid);if(l){const c=l.cats.find(x=>x.id===cid);if(c)c.exp=!c.exp;}DB.set('lib-structure',ls);buildLibTree(document.getElementById('lib-search').value||'');}
