function openPointNameBuilderModal(objId, pi) {
  const cs  = S.canvas || { objects: [] };
  const obj = (cs.objects||[]).find(o => o.id === objId);
  if (!obj || !obj.points?.[pi]) return;

  const pt  = obj.points[pi];
