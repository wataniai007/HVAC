function addSequence() {
  if (!S.project) return;
  if (!S.project.sequences) S.project.sequences = [];
  S.project.sequences.push({ title:'New Sequence', context:'', tag:'', sections:[{ title:'1. Description', content:'' }] });
  S._selectedSeq = S.project.sequences.length - 1;
  if (typeof addAudit === 'function') addAudit('canvas', 'Sequence added');
  if (typeof saveCS === 'function') saveCS();
  renderSequenceEditor();
}

function selectSequence(i) {
  S._selectedSeq = i;
  renderSequenceEditor();
}

function updateSeqField(field, val) {
  if (!S.project?.sequences?.[S._selectedSeq]) return;
  S.project.sequences[S._selectedSeq][field] = val;
  if (typeof saveCS === 'function') saveCS();
}

function updateSeqSection(si, field, val) {
  if (!S.project?.sequences?.[S._selectedSeq]?.sections) return;
  S.project.sequences[S._selectedSeq].sections[si][field] = val;
  if (typeof saveCS === 'function') saveCS();
}

function addSeqSection() {
  if (!S.project?.sequences?.[S._selectedSeq]) return;
  const seq = S.project.sequences[S._selectedSeq];
  if (!seq.sections) seq.sections = [];
  seq.sections.push({ title: (seq.sections.length + 1) + '. New Section', content: '' });
  if (typeof saveCS === 'function') saveCS();
  renderSequenceEditor();
}

function deleteSeqSection(si) {
  if (!S.project?.sequences?.[S._selectedSeq]?.sections) return;
  S.project.sequences[S._selectedSeq].sections.splice(si, 1);
  if (typeof saveCS === 'function') saveCS();
  renderSequenceEditor();
}

function deleteSequence(i) {
  if (!S.project?.sequences) return;
  if (!confirm('Delete this sequence?')) return;
  S.project.sequences.splice(i, 1);
  S._selectedSeq = undefined;
  if (typeof addAudit === 'function') addAudit('canvas', 'Sequence deleted');
  if (typeof saveCS === 'function') saveCS();
  renderSequenceEditor();
}

function loadSeqTemplate(name) {
  if (!name || !SEQ_TEMPLATES[name]) return;
  if (!S.project?.sequences?.[S._selectedSeq]) return;
  const seq  = S.project.sequences[S._selectedSeq];
  const tmpl = SEQ_TEMPLATES[name];
  seq.sections = JSON.parse(JSON.stringify(tmpl.sections));
  // Replace variables with project data
  const tag  = seq.tag || '{TAG}';
  const ctx  = seq.context || '{CONTEXT}';
  seq.sections.forEach(sec => {
    sec.content = sec.content.replace(/\{TAG\}/g, tag).replace(/\{LOCATION\}/g, ctx);
  });
  if (typeof saveCS === 'function') saveCS();
  renderSequenceEditor();
  toast('Template loaded: ' + name, 'success');
}

function exportSeqPDF() {
  if (!S.project?.sequences?.[S._selectedSeq]) return;
  const seq  = S.project.sequences[S._selectedSeq];
  const proj = S.project;
  const win  = window.open('', '_blank');
  win.document.write('<!DOCTYPE html><html><head><title>' + seq.title + '</title>'
